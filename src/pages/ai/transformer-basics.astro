---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const transformerImage = '/transformer-architecture.png';
---

<Layout
  title="Transformer Basics | Saurav Tripathy"
  description="A beginner-friendly explanation of how transformer architecture works."
  showFooterCta={false}
>
  <SiteHeader />

  <main class="min-h-screen bg-[#f8fbff] px-6 py-16 text-[#06142f]">
    <section class="mx-auto max-w-7xl">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-700">
        AI Understanding
      </p>

      <h1 class="mt-5 text-3xl font-semibold tracking-[-0.04em] sm:text-5xl">
        Transformer Basics
      </h1>

      <div class="mt-12 grid gap-8 lg:grid-cols-2 lg:items-stretch">
       
         <!-- Left half: photo area -->
          <div
            class="h-[560px] cursor-zoom-in overflow-hidden rounded-3xl border border-blue-100 bg-white shadow-sm lg:h-[680px]"
            data-full-image={transformerImage}
            role="button"
            tabindex="0"
            aria-label="Open transformer architecture image at full size"
            title="Double-click to open full-size image"
          >
            <img
              src={transformerImage}
              alt="Transformer architecture visual"
              class="h-full w-full object-contain p-6"
            />
          </div>

        <!-- Right half: scrollable text box -->
        <article class="h-[560px] overflow-y-auto rounded-3xl border border-slate-200 bg-white p-8 shadow-sm scroll-box sm:p-10 lg:h-[680px]">
        
          <h2 class="mt-4 text-3xl font-semibold tracking-[-0.03em] text-[#06142f]">
            What is a transformer?
          </h2>

          <div class="mt-6 space-y-4 text-lg leading-6 text-slate-700">
            <p>
              A transformer is the core architecture behind modern large language
              models. It takes text, breaks it into smaller pieces called tokens,
              turns those tokens into numbers, and then learns how each token
              relates to the others.
            </p>

            <p>
              The key idea is attention. Instead of reading words one by one like
              older models, a transformer can look across the full sentence and
              decide which words matter most for understanding the current word.
            </p>

            <p>
              For example, in the sentence “The dog chased the ball because it was
              excited,” the model needs to understand that “it” probably refers to
              the dog. Attention helps the model make that connection.
            </p>

            <h3 class="pt-4 text-2xl font-semibold tracking-[-0.02em] text-[#06142f]">
              The basic flow
            </h3>

            <p>
              First, text is split into tokens. Then each token is converted into an
              embedding, which is just a vector of numbers. Positional information is
              added so the model knows the order of the words.
            </p>

            <p>
              The model then passes these embeddings through layers of attention and
              feed-forward neural networks. Each layer refines the model’s
              understanding of the sentence.
            </p>

            <p>
              At the end, the model predicts the most likely next token. Repeating
              this process again and again is how a model generates full responses.
            </p>

            <h3 class="pt-4 text-2xl font-semibold tracking-[-0.02em] text-[#06142f]">
              Why it matters
            </h3>

            <p>
              Transformers made AI much better at language because they can capture
              context, relationships, and meaning across long pieces of text. That is
              why they power chatbots, coding assistants, summarization tools, search,
              agents, and many modern AI applications.
            </p>
          </div>
        </article>
      </div>
      <!-- Full-size image overlay -->
      <div
        id="image-lightbox"
        class="fixed inset-0 z-50 hidden overflow-auto bg-black/90 p-8"
        aria-hidden="true"
      >
        <button
          id="close-lightbox"
          type="button"
          class="fixed right-6 top-6 rounded-full bg-white px-4 py-2 text-sm font-semibold text-slate-900 shadow-lg"
          aria-label="Close full-size image"
        >
          Esc / Close
        </button>

        <div class="flex min-h-full items-center justify-center">
          <img
            id="lightbox-image"
            src=""
            alt="Full-size transformer architecture visual"
            class="max-w-none"
          />
        </div>
      </div>

    </section>
  </main>
</Layout>

<script>
  const imageBlock = document.querySelector('[data-full-image]');
  const lightbox = document.querySelector('#image-lightbox');
  const lightboxImage = document.querySelector('#lightbox-image');
  const closeButton = document.querySelector('#close-lightbox');

  const openLightbox = () => {
    if (!(imageBlock instanceof HTMLElement)) return;
    if (!(lightbox instanceof HTMLElement)) return;
    if (!(lightboxImage instanceof HTMLImageElement)) return;

    const imageUrl = imageBlock.dataset.fullImage;

    if (!imageUrl) return;

    lightboxImage.src = imageUrl;
    lightbox.classList.remove('hidden');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const closeLightbox = () => {
    if (!(lightbox instanceof HTMLElement)) return;
    if (!(lightboxImage instanceof HTMLImageElement)) return;

    lightbox.classList.add('hidden');
    lightbox.setAttribute('aria-hidden', 'true');
    lightboxImage.src = '';
    document.body.style.overflow = '';
  };

  imageBlock?.addEventListener('click', openLightbox);

  imageBlock?.addEventListener('keydown', (event) => {
    if (event instanceof KeyboardEvent && event.key === 'Enter') {
      openLightbox();
    }
  });

  closeButton?.addEventListener('click', closeLightbox);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeLightbox();
    }
  });

  lightbox?.addEventListener('click', (event) => {
    if (event.target === lightbox) {
      closeLightbox();
    }
  });
</script>

<style>
  .scroll-box {
    scrollbar-width: thin;
    scrollbar-color: #2563eb #e2e8f0;
  }

  .scroll-box::-webkit-scrollbar {
    width: 10px;
  }

  .scroll-box::-webkit-scrollbar-track {
    background: #e2e8f0;
    border-radius: 999px;
  }

  .scroll-box::-webkit-scrollbar-thumb {
    background: #2563eb;
    border-radius: 999px;
  }
</style>
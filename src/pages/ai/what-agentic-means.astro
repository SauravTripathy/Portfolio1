---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const agenticImages = [
  {
    src: '/what-agentic-means-1.png',
    alt: 'Agentic AI concept diagram one',
    caption: 'What makes an AI system agentic',
  },
  {
    src: '/what-agentic-means-2.png',
    alt: 'Agentic AI concept diagram two',
    caption: 'How agentic systems work in practice',
  },
];
---

<Layout
  title="What Agentic Means | Saurav Tripathy"
  description="A beginner-friendly explanation of what agentic AI means."
  showFooterCta={false}
>
  <SiteHeader />

  <main class="min-h-screen bg-[#f8fbff] px-6 py-16 text-[#06142f]">
    <section class="mx-auto max-w-7xl">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-700">
        AI Understanding
      </p>

      <h1 class="mt-5 text-3xl font-semibold tracking-[-0.04em] sm:text-5xl">
        What Agentic Means
      </h1>

      <!-- Image carousel section -->
      <section
        class="mt-12 rounded-3xl border border-blue-100 bg-white p-4 shadow-sm sm:p-5"
        data-agentic-carousel
        aria-label="Agentic AI image carousel"
      >
        <div class="relative h-[420px] overflow-hidden rounded-2xl bg-white lg:h-[560px]">
          <!-- Clickable image layer: opens enlarged view -->
          <button
            type="button"
            class="absolute inset-0 z-0 h-full w-full cursor-zoom-in"
            data-open-lightbox
            aria-label="Open current image at full size"
            title="Click image to expand"
          >
            {
              agenticImages.map((image, index) => (
                <img
                  src={image.src}
                  alt={image.alt}
                  data-carousel-image
                  data-caption={image.caption}
                  data-index={index}
                  class:list={[
                    'h-full w-full object-contain p-4',
                    index !== 0 && 'hidden',
                  ]}
                  loading={index === 0 ? 'eager' : 'lazy'}
                />
              ))
            }
          </button>

          <!-- Default panel arrows -->
          <button
            type="button"
            class="pointer-events-auto absolute left-4 top-1/2 z-30 grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full bg-white/95 text-4xl font-semibold leading-none text-[#06142f] shadow transition hover:bg-white"
            data-main-prev
            aria-label="Show previous image"
            title="Previous image"
          >
            ‹
          </button>

          <button
            type="button"
            class="pointer-events-auto absolute right-4 top-1/2 z-30 grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full bg-white/95 text-4xl font-semibold leading-none text-[#06142f] shadow transition hover:bg-white"
            data-main-next
            aria-label="Show next image"
            title="Next image"
          >
            ›
          </button>
        </div>

        <div class="mt-4 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-sm font-medium text-slate-600" data-carousel-footnote>
            Diagram 1 of {agenticImages.length}: {agenticImages[0].caption}
          </p>

          <div class="flex items-center gap-3" aria-label="Choose image">
            {
              agenticImages.map((image, index) => (
                <button
                  type="button"
                  class:list={[
                    'h-3 w-3 rounded-full transition',
                    index === 0 ? 'bg-blue-700' : 'bg-slate-300',
                  ]}
                  data-carousel-dot
                  data-index={index}
                  aria-label={`Show diagram ${index + 1}`}
                  title={`Diagram ${index + 1}: ${image.caption}`}
                  aria-current={index === 0 ? 'true' : 'false'}
                />
              ))
            }
          </div>
        </div>
      </section>

      <!-- Full-size image overlay -->
      <div
        id="image-lightbox"
        class="fixed inset-0 z-50 hidden overflow-auto bg-black/90 p-4 sm:p-8"
        aria-hidden="true"
        role="dialog"
        aria-modal="true"
        aria-label="Expanded image viewer"
      >
        <button
          type="button"
          id="lightbox-close"
          class="fixed right-5 top-5 z-[60] grid h-11 w-11 place-items-center rounded-full bg-white/90 text-2xl font-semibold text-[#06142f] shadow transition hover:bg-white"
          aria-label="Close full-size image"
          title="Close image"
        >
          ×
        </button>

        <button
          type="button"
          id="lightbox-prev"
          class="fixed left-5 top-1/2 z-[60] grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-3xl font-semibold text-[#06142f] shadow transition hover:bg-white"
          aria-label="Show previous full-size image"
          title="Previous image"
        >
          ‹
        </button>

        <button
          type="button"
          id="lightbox-next"
          class="fixed right-5 top-1/2 z-[60] grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-3xl font-semibold text-[#06142f] shadow transition hover:bg-white"
          aria-label="Show next full-size image"
          title="Next image"
        >
          ›
        </button>

        <div class="flex min-h-full flex-col items-center justify-center gap-4">
          <img
            id="lightbox-image"
            src={agenticImages[0].src}
            alt={agenticImages[0].alt}
            class="max-h-[84vh] max-w-[95vw] cursor-zoom-out rounded-2xl bg-white object-contain"
            title="Click image to close"
          />

          <p
            id="lightbox-footnote"
            class="max-w-4xl text-center text-sm font-medium text-white/80"
          >
            Diagram 1 of {agenticImages.length}: {agenticImages[0].caption}
          </p>
        </div>
      </div>
    </section>
  </main>

  <script>
    const carouselImages = Array.from(
      document.querySelectorAll<HTMLImageElement>('[data-carousel-image]')
    );

    const openLightboxButton = document.querySelector<HTMLButtonElement>(
      '[data-open-lightbox]'
    );

    const mainPrevButton = document.querySelector<HTMLButtonElement>(
      '[data-main-prev]'
    );

    const mainNextButton = document.querySelector<HTMLButtonElement>(
      '[data-main-next]'
    );

    const carouselDots = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-carousel-dot]')
    );

    const carouselFootnote = document.querySelector<HTMLElement>(
      '[data-carousel-footnote]'
    );

    const lightbox = document.querySelector<HTMLElement>('#image-lightbox');

    const lightboxImage = document.querySelector<HTMLImageElement>(
      '#lightbox-image'
    );

    const lightboxFootnote = document.querySelector<HTMLElement>(
      '#lightbox-footnote'
    );

    const lightboxCloseButton = document.querySelector<HTMLButtonElement>(
      '#lightbox-close'
    );

    const lightboxPrevButton = document.querySelector<HTMLButtonElement>(
      '#lightbox-prev'
    );

    const lightboxNextButton = document.querySelector<HTMLButtonElement>(
      '#lightbox-next'
    );

    let activeIndex = 0;
    const totalImages = carouselImages.length;

    const isLightboxOpen = (): boolean => {
      return Boolean(lightbox && !lightbox.classList.contains('hidden'));
    };

    const getActiveImage = (): HTMLImageElement | undefined => {
      return carouselImages[activeIndex];
    };

    const getFootnoteText = (): string => {
      const activeImage = getActiveImage();
      const caption = activeImage?.dataset.caption ?? '';

      return `Diagram ${activeIndex + 1} of ${totalImages}: ${caption}`;
    };

    const updateLightboxImage = (): void => {
      const activeImage = getActiveImage();

      if (!activeImage || !lightboxImage) return;

      lightboxImage.src = activeImage.src;
      lightboxImage.alt = activeImage.alt;

      if (lightboxFootnote) {
        lightboxFootnote.textContent = getFootnoteText();
      }
    };

    const setActiveImage = (nextIndex: number): void => {
      if (!totalImages) return;

      activeIndex = (nextIndex + totalImages) % totalImages;

      carouselImages.forEach((image, index) => {
        image.classList.toggle('hidden', index !== activeIndex);
      });

      carouselDots.forEach((dot, index) => {
        dot.classList.toggle('bg-blue-700', index === activeIndex);
        dot.classList.toggle('bg-slate-300', index !== activeIndex);
        dot.setAttribute(
          'aria-current',
          index === activeIndex ? 'true' : 'false'
        );
      });

      if (carouselFootnote) {
        carouselFootnote.textContent = getFootnoteText();
      }

      if (isLightboxOpen()) {
        updateLightboxImage();
      }
    };

    const showPreviousImage = (): void => {
      setActiveImage(activeIndex - 1);
    };

    const showNextImage = (): void => {
      setActiveImage(activeIndex + 1);
    };

    const openLightbox = (): void => {
      if (!lightbox) return;

      updateLightboxImage();

      lightbox.classList.remove('hidden');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = (): void => {
      if (!lightbox) return;

      lightbox.classList.add('hidden');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    openLightboxButton?.addEventListener('click', openLightbox);

    openLightboxButton?.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        openLightbox();
      }
    });

    mainPrevButton?.addEventListener('click', (event: MouseEvent) => {
      event.preventDefault();
      event.stopPropagation();
      showPreviousImage();
    });

    mainNextButton?.addEventListener('click', (event: MouseEvent) => {
      event.preventDefault();
      event.stopPropagation();
      showNextImage();
    });

    carouselDots.forEach((dot) => {
      dot.addEventListener('click', (event: MouseEvent) => {
        event.preventDefault();
        event.stopPropagation();

        const index = Number(dot.dataset.index);

        if (Number.isNaN(index)) return;

        setActiveImage(index);
      });
    });

    lightboxCloseButton?.addEventListener('click', (event: MouseEvent) => {
      event.stopPropagation();
      closeLightbox();
    });

    lightboxPrevButton?.addEventListener('click', (event: MouseEvent) => {
      event.stopPropagation();
      showPreviousImage();
    });

    lightboxNextButton?.addEventListener('click', (event: MouseEvent) => {
      event.stopPropagation();
      showNextImage();
    });

    lightboxImage?.addEventListener('click', (event: MouseEvent) => {
      event.stopPropagation();
      closeLightbox();
    });

    lightbox?.addEventListener('click', closeLightbox);

    document.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key === 'Escape') {
        closeLightbox();
      }

      if (!isLightboxOpen()) return;

      if (event.key === 'ArrowLeft') {
        showPreviousImage();
      }

      if (event.key === 'ArrowRight') {
        showNextImage();
      }
    });

    setActiveImage(0);
  </script>
</Layout>
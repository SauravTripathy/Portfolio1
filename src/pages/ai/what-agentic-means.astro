---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const topAgenticImage = '/what-agentic-means-1.png';
const bottomAgenticImage = '/what-agentic-means-2.png';
---

<Layout
  title="What &quot;Agentic&quot; Means | Saurav Tripathy"
  description="A beginner-friendly explanation of what agentic AI means."
  showFooterCta={false}
>
  <SiteHeader />

  <main class="min-h-screen bg-[#f8fbff] px-6 py-16 text-[#06142f]">
    <section class="mx-auto max-w-7xl">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-700">
        AI Understanding
      </p>

      <h1 class="mt-5 text-3xl font-semibold tracking-[-0.04em] sm:text-5xl">
        What &quot;Agentic&quot; Means
      </h1>

      <div class="mt-12 grid gap-8">
        <!-- Top panel: clickable image area -->
        <div
          class="h-[420px] cursor-zoom-in overflow-hidden rounded-3xl border border-blue-100 bg-white shadow-sm transition hover:shadow-md lg:h-[560px]"
          data-full-image={topAgenticImage}
          role="button"
          tabindex="0"
          aria-label="Open what agentic means diagram one at full size"
          aria-expanded="false"
          title="Click to expand image"
        >
          <img
            src={topAgenticImage}
            alt="What agentic means diagram one"
            class="h-full w-full object-contain p-4"
            loading="eager"
          />
        </div>

        <!-- Bottom panel: clickable image area -->
        <div
          class="h-[420px] cursor-zoom-in overflow-hidden rounded-3xl border border-blue-100 bg-white shadow-sm transition hover:shadow-md lg:h-[560px]"
          data-full-image={bottomAgenticImage}
          role="button"
          tabindex="0"
          aria-label="Open what agentic means diagram two at full size"
          aria-expanded="false"
          title="Click to expand image"
        >
          <img
            src={bottomAgenticImage}
            alt="What agentic means diagram two"
            class="h-full w-full object-contain p-4"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Full-size image overlay -->
      <div
        id="image-lightbox"
        class="fixed inset-0 z-50 hidden cursor-zoom-out overflow-auto bg-black/90 p-4 sm:p-8"
        aria-hidden="true"
        role="button"
        tabindex="0"
        aria-label="Close full-size image"
        title="Click to close image"
      >
        <div class="flex min-h-full items-center justify-center">
          <img
            id="lightbox-image"
            src=""
            alt="Full-size image"
            class="max-w-none cursor-zoom-out rounded-2xl bg-white"
          />
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const imageBlocks = document.querySelectorAll<HTMLElement>('[data-full-image]');
  const lightbox = document.querySelector<HTMLElement>('#image-lightbox');
  const lightboxImage = document.querySelector<HTMLImageElement>('#lightbox-image');

  let activeImageBlock: HTMLElement | null = null;

  const openLightbox = (imageBlock: HTMLElement): void => {
    if (!lightbox || !lightboxImage) return;

    const imageUrl = imageBlock.dataset.fullImage;
    if (!imageUrl) return;

    const inlineImage = imageBlock.querySelector<HTMLImageElement>('img');

    activeImageBlock = imageBlock;

    lightboxImage.src = imageUrl;
    lightboxImage.alt = inlineImage?.alt || 'Full-size image';

    lightbox.classList.remove('hidden');
    lightbox.setAttribute('aria-hidden', 'false');
    imageBlock.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeLightbox = (): void => {
    if (!lightbox || !lightboxImage) return;

    lightbox.classList.add('hidden');
    lightbox.setAttribute('aria-hidden', 'true');

    lightboxImage.src = '';
    lightboxImage.alt = 'Full-size image';

    activeImageBlock?.setAttribute('aria-expanded', 'false');
    activeImageBlock = null;

    document.body.style.overflow = '';
  };

  imageBlocks.forEach((imageBlock) => {
    imageBlock.addEventListener('click', () => {
      openLightbox(imageBlock);
    });

    imageBlock.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        openLightbox(imageBlock);
      }
    });
  });

  lightbox?.addEventListener('click', closeLightbox);

  lightbox?.addEventListener('keydown', (event: KeyboardEvent) => {
    if (event.key === 'Enter' || event.key === ' ') {
      event.preventDefault();
      closeLightbox();
    }
  });

  document.addEventListener('keydown', (event: KeyboardEvent) => {
    if (event.key === 'Escape') {
      closeLightbox();
    }
  });
</script>
---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const agenticImages = [
  {
    src: '/what-agentic-means-1.png',
    alt: 'Agentic AI concept diagram one',
    caption: 'Diagram 1: What makes an AI system agentic',
  },
  {
    src: '/what-agentic-means-2.png',
    alt: 'Agentic AI concept diagram two',
    caption: 'Diagram 2: How agentic systems work in practice',
  },
];
---

<Layout
  title="What Agentic Means | Saurav Tripathy"
  description="A beginner-friendly explanation of what agentic AI means."
  showFooterCta={false}
>
  <SiteHeader />

  <main class="min-h-screen bg-[#f8fbff] px-6 py-16 text-[#06142f]">
    <section class="mx-auto max-w-7xl">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-700">
        AI Understanding
      </p>

      <h1 class="mt-5 text-3xl font-semibold tracking-[-0.04em] sm:text-5xl">
        What Agentic Means
      </h1>

      <div class="mt-12 grid gap-8">
        <!-- Top section: two-image carousel with expandable lightbox -->
        <section
          class="rounded-3xl border border-blue-100 bg-white p-4 shadow-sm sm:p-5"
          data-agentic-carousel
          aria-label="Agentic AI image carousel"
        >
          <div class="relative h-[420px] overflow-hidden rounded-2xl bg-white lg:h-[560px]">
            <button
              type="button"
              class="absolute left-4 top-1/2 z-10 grid h-11 w-11 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-3xl font-semibold text-[#06142f] shadow transition hover:bg-white"
              data-carousel-prev
              aria-label="Show previous image"
              title="Previous image"
            >
              ‹
            </button>

            <div
              class="h-full cursor-zoom-in"
              data-carousel-open
              role="button"
              tabindex="0"
              aria-label="Open current image at full size"
              title="Click to expand image"
            >
              {
                agenticImages.map((image, index) => (
                  <img
                    src={image.src}
                    alt={image.alt}
                    data-carousel-image
                    data-caption={image.caption}
                    data-index={index}
                    class:list={[
                      'h-full w-full object-contain p-4',
                      index !== 0 && 'hidden',
                    ]}
                    loading={index === 0 ? 'eager' : 'lazy'}
                  />
                ))
              }
            </div>

            <button
              type="button"
              class="absolute right-4 top-1/2 z-10 grid h-11 w-11 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-3xl font-semibold text-[#06142f] shadow transition hover:bg-white"
              data-carousel-next
              aria-label="Show next image"
              title="Next image"
            >
              ›
            </button>
          </div>

          <div class="mt-4 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <p
              class="text-sm font-medium text-slate-600"
              data-carousel-caption
            >
              {agenticImages[0].caption}
            </p>

            <div class="flex items-center gap-2" aria-label="Choose image">
              {
                agenticImages.map((image, index) => (
                  <button
                    type="button"
                    class:list={[
                      'h-2.5 w-2.5 rounded-full transition',
                      index === 0 ? 'bg-blue-700' : 'bg-slate-300',
                    ]}
                    data-carousel-dot
                    data-index={index}
                    aria-label={`Show ${image.caption}`}
                    title={image.caption}
                  />
                ))
              }
            </div>
          </div>
        </section>

        <!-- Bottom section: scrollable text area -->
        <article class="scroll-box h-[560px] overflow-y-auto rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10 lg:h-[680px]">
          <h2 class="text-2xl font-bold tracking-[-0.03em] text-[#073763] sm:text-3xl">
            What does “agentic” actually mean?
          </h2>

          <div class="mt-6 space-y-5 text-sm leading-7 text-slate-700 sm:text-base">
            <p>
              Add your explanation here. This section is scrollable, so you can
              write a longer article without stretching the entire page too much.
            </p>

            <p>
              A simple way to explain agentic AI: instead of only answering a
              question, the system can reason through a goal, choose steps, use
              tools, observe results, and continue until the task is complete.
            </p>

            <h3 class="pt-4 text-xl font-semibold tracking-[-0.02em] text-[#06142f]">
              Assistants vs agents
            </h3>

            <p>
              A normal assistant usually responds to a user request. An agentic
              system goes further: it can decide what action to take next, call
              tools, interact with systems, and adapt based on feedback.
            </p>

            <h3 class="pt-4 text-xl font-semibold tracking-[-0.02em] text-[#06142f]">
              Why it matters
            </h3>

            <p>
              Agentic systems can unlock more complex workflows, but they also
              add more complexity. Once AI starts taking actions instead of only
              giving answers, teams need stronger boundaries, permissions,
              monitoring, and accountability.
            </p>

            <p>
              Replace this placeholder text with your final writing.
            </p>
          </div>
        </article>
      </div>

      <!-- Full-size image overlay -->
      <div
        id="image-lightbox"
        class="fixed inset-0 z-50 hidden cursor-zoom-out overflow-auto bg-black/90 p-4 sm:p-8"
        aria-hidden="true"
        role="dialog"
        aria-modal="true"
        aria-label="Expanded image viewer"
      >
        <button
          type="button"
          id="lightbox-close"
          class="fixed right-5 top-5 z-[60] grid h-11 w-11 place-items-center rounded-full bg-white/90 text-2xl font-semibold text-[#06142f] shadow transition hover:bg-white"
          aria-label="Close full-size image"
          title="Close image"
        >
          ×
        </button>

        <button
          type="button"
          id="lightbox-prev"
          class="fixed left-5 top-1/2 z-[60] grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-3xl font-semibold text-[#06142f] shadow transition hover:bg-white"
          aria-label="Show previous full-size image"
          title="Previous image"
        >
          ‹
        </button>

        <button
          type="button"
          id="lightbox-next"
          class="fixed right-5 top-1/2 z-[60] grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-3xl font-semibold text-[#06142f] shadow transition hover:bg-white"
          aria-label="Show next full-size image"
          title="Next image"
        >
          ›
        </button>

        <div class="flex min-h-full items-center justify-center">
          <img
            id="lightbox-image"
            src=""
            alt=""
            class="max-h-[90vh] max-w-[95vw] cursor-zoom-out rounded-2xl bg-white object-contain"
            title="Click image to close"
          />
        </div>
      </div>
    </section>
  </main>

  <script>
    const carouselImages = Array.from(
      document.querySelectorAll('[data-carousel-image]')
    );

    const carouselOpen = document.querySelector('[data-carousel-open]');
    const carouselPrev = document.querySelector('[data-carousel-prev]');
    const carouselNext = document.querySelector('[data-carousel-next]');
    const carouselDots = Array.from(
      document.querySelectorAll('[data-carousel-dot]')
    );
    const carouselCaption = document.querySelector('[data-carousel-caption]');

    const lightbox = document.querySelector('#image-lightbox');
    const lightboxImage = document.querySelector('#lightbox-image');
    const lightboxClose = document.querySelector('#lightbox-close');
    const lightboxPrev = document.querySelector('#lightbox-prev');
    const lightboxNext = document.querySelector('#lightbox-next');

    let activeIndex = 0;

    const isLightboxOpen = () => {
      return (
        lightbox instanceof HTMLElement &&
        !lightbox.classList.contains('hidden')
      );
    };

    const getActiveImage = () => {
      return carouselImages[activeIndex];
    };

    const updateLightboxImage = () => {
      if (!(lightboxImage instanceof HTMLImageElement)) return;

      const activeImage = getActiveImage();
      if (!(activeImage instanceof HTMLImageElement)) return;

      lightboxImage.src = activeImage.src;
      lightboxImage.alt = activeImage.alt;
    };

const setActiveImage = (nextIndex: number): void => {
      if (!carouselImages.length) return;

      activeIndex =
        (nextIndex + carouselImages.length) % carouselImages.length;

      carouselImages.forEach((image, index) => {
        image.classList.toggle('hidden', index !== activeIndex);
      });

      carouselDots.forEach((dot, index) => {
        dot.classList.toggle('bg-blue-700', index === activeIndex);
        dot.classList.toggle('bg-slate-300', index !== activeIndex);
        dot.setAttribute(
          'aria-current',
          index === activeIndex ? 'true' : 'false'
        );
      });

      const activeImage = getActiveImage();

      if (
        activeImage instanceof HTMLImageElement &&
        carouselCaption instanceof HTMLElement
      ) {
        carouselCaption.textContent =
          activeImage.dataset.caption || `Diagram ${activeIndex + 1}`;
      }

      if (isLightboxOpen()) {
        updateLightboxImage();
      }
    };

    const showPreviousImage = () => {
      setActiveImage(activeIndex - 1);
    };

    const showNextImage = () => {
      setActiveImage(activeIndex + 1);
    };

    const openLightbox = () => {
      if (!(lightbox instanceof HTMLElement)) return;

      updateLightboxImage();

      lightbox.classList.remove('hidden');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      if (!(lightbox instanceof HTMLElement)) return;
      if (!(lightboxImage instanceof HTMLImageElement)) return;

      lightbox.classList.add('hidden');
      lightbox.setAttribute('aria-hidden', 'true');
      lightboxImage.src = '';
      lightboxImage.alt = '';
      document.body.style.overflow = '';
    };

    carouselOpen?.addEventListener('click', openLightbox);

    carouselOpen?.addEventListener('keydown', (event) => {
      if (!(event instanceof KeyboardEvent)) return;

      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        openLightbox();
      }
    });

    carouselPrev?.addEventListener('click', (event) => {
      event.stopPropagation();
      showPreviousImage();
    });

    carouselNext?.addEventListener('click', (event) => {
      event.stopPropagation();
      showNextImage();
    });

    carouselDots.forEach((dot) => {
      dot.addEventListener('click', () => {
        if (!(dot instanceof HTMLElement)) return;

        const index = Number(dot.dataset.index);
        if (Number.isNaN(index)) return;

        setActiveImage(index);
      });
    });

    lightboxClose?.addEventListener('click', (event) => {
      event.stopPropagation();
      closeLightbox();
    });

    lightboxPrev?.addEventListener('click', (event) => {
      event.stopPropagation();
      showPreviousImage();
    });

    lightboxNext?.addEventListener('click', (event) => {
      event.stopPropagation();
      showNextImage();
    });

    lightboxImage?.addEventListener('click', (event) => {
      event.stopPropagation();
      closeLightbox();
    });

    lightbox?.addEventListener('click', closeLightbox);

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeLightbox();
      }

      if (!isLightboxOpen()) return;

      if (event.key === 'ArrowLeft') {
        showPreviousImage();
      }

      if (event.key === 'ArrowRight') {
        showNextImage();
      }
    });

    setActiveImage(0);
  </script>
</Layout>

<style>
  .scroll-box {
    scrollbar-width: thin;
    scrollbar-color: #2563eb #e2e8f0;
  }

  .scroll-box::-webkit-scrollbar {
    width: 10px;
  }

  .scroll-box::-webkit-scrollbar-track {
    background: #e2e8f0;
    border-radius: 999px;
  }

  .scroll-box::-webkit-scrollbar-thumb {
    background: #2563eb;
    border-radius: 999px;
  }
</style>
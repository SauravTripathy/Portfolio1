---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const solutionLandscapeImage = '/GenAI_Solution_Landscape.png';
const productivityComplexityImage = '/productivity_complexity.png';
---

<Layout
  title="AI Solution Types | Saurav Tripathy"
  description="A beginner-friendly breakdown of different AI solution types."
  showFooterCta={false}
>
  <SiteHeader />

  <main class="min-h-screen bg-[#f8fbff] px-4 py-10 text-[#06142f] sm:px-6 sm:py-16">
    <section class="mx-auto max-w-7xl">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-700">
        AI Understanding
      </p>

      <h1 class="mt-5 text-3xl font-semibold tracking-[-0.04em] sm:text-5xl">
        AI Solution Types
      </h1>

      <div class="mt-12 grid gap-8">
        <!-- Top panel: clickable image area -->
        <div
          class="cursor-zoom-in overflow-hidden rounded-3xl border border-blue-100 bg-white shadow-sm transition hover:shadow-md lg:h-[560px]"
          data-full-image={solutionLandscapeImage}
          role="button"
          tabindex="0"
          aria-label="Open generative AI solution landscape image at full size"
          title="Click to expand image"
        >
          <img
            src={solutionLandscapeImage}
            alt="Generative AI solution landscape"
            class="h-auto w-full p-3 sm:p-4 lg:h-full lg:object-contain"
            loading="eager"
          />
        </div>

        <!-- Bottom panel: clickable productivity/complexity image area -->
<div
  class="cursor-zoom-in overflow-hidden rounded-3xl border border-blue-100 bg-white shadow-sm transition hover:shadow-md lg:h-[560px]"
  data-full-image={productivityComplexityImage}
  role="button"
  tabindex="0"
  aria-label="Open productivity complexity image at full size"
  title="Click to expand image"
>
  <img
    src={productivityComplexityImage}
    alt="Productivity complexity diagram"
    class="h-auto w-full p-3 sm:p-4 lg:h-full lg:object-contain"
    loading="eager"
  />
</div>
      </div>

      <!-- Full-size image overlay -->
      <div
        id="image-lightbox"
        class="fixed inset-0 z-50 hidden cursor-zoom-out overflow-auto bg-black/90 p-4 sm:p-8"
        aria-hidden="true"
        role="button"
        tabindex="0"
        aria-label="Close full-size image"
        title="Click to close image"
      >
        <div class="flex min-h-full items-center justify-center">
          <img
            id="lightbox-image"
            src=""
            alt="Full-size generative AI solution landscape"
            class="max-w-none cursor-zoom-out rounded-2xl bg-white"
          />
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const imageBlocks = document.querySelectorAll<HTMLElement>('[data-full-image]');
  const lightbox = document.querySelector<HTMLElement>('#image-lightbox');
  const lightboxImage = document.querySelector<HTMLImageElement>('#lightbox-image');

  let activeImageBlock: HTMLElement | null = null;

  const openLightbox = (imageBlock: HTMLElement): void => {
    if (!lightbox || !lightboxImage) return;

    const imageUrl = imageBlock.dataset.fullImage;
    if (!imageUrl) return;

    const inlineImage = imageBlock.querySelector<HTMLImageElement>('img');

    activeImageBlock = imageBlock;
    lightboxImage.src = imageUrl;
    lightboxImage.alt = inlineImage?.alt || 'Full-size image';

    lightbox.classList.remove('hidden');
    lightbox.setAttribute('aria-hidden', 'false');
    imageBlock.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeLightbox = (): void => {
    if (!lightbox || !lightboxImage) return;

    lightbox.classList.add('hidden');
    lightbox.setAttribute('aria-hidden', 'true');
    lightboxImage.src = '';
    lightboxImage.alt = 'Full-size image';

    activeImageBlock?.setAttribute('aria-expanded', 'false');
    activeImageBlock = null;

    document.body.style.overflow = '';
  };

  imageBlocks.forEach((imageBlock: HTMLElement) => {
    imageBlock.setAttribute('aria-expanded', 'false');

    imageBlock.addEventListener('click', () => {
      openLightbox(imageBlock);
    });

    imageBlock.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        openLightbox(imageBlock);
      }
    });
  });

  lightbox?.addEventListener('click', closeLightbox);

  lightbox?.addEventListener('keydown', (event: KeyboardEvent) => {
    if (event.key === 'Enter' || event.key === ' ') {
      event.preventDefault();
      closeLightbox();
    }
  });

  document.addEventListener('keydown', (event: KeyboardEvent) => {
    if (event.key === 'Escape') {
      closeLightbox();
    }
  });
</script>
---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const solutionLandscapeImage = '/GenAI_Solution_Landscape.PNG';
---

<Layout
  title="AI Solution Types | Saurav Tripathy"
  description="A beginner-friendly breakdown of different AI solution types."
  showFooterCta={false}
>
  <SiteHeader />

  <main class="min-h-screen bg-[#f8fbff] px-6 py-16 text-[#06142f]">
    <section class="mx-auto max-w-7xl">
      <p class="text-sm font-semibold uppercase tracking-[0.28em] text-blue-700">
        AI Understanding
      </p>

      <h1 class="mt-5 text-3xl font-semibold tracking-[-0.04em] sm:text-5xl">
        AI Solution Types
      </h1>

      <!-- Same structure as transformer-basics, but stacked vertically -->
      <div class="mt-12 grid gap-8">
        <!-- Top panel: clickable image area -->
        <div
          class="h-[420px] cursor-zoom-in overflow-hidden rounded-3xl border border-blue-100 bg-white shadow-sm transition hover:shadow-md lg:h-[560px]"
          data-full-image={solutionLandscapeImage}
          role="button"
          tabindex="0"
          aria-label="Open generative AI solution landscape image at full size"
          title="Click to expand image"
        >
          <img
            src={solutionLandscapeImage}
            alt="Generative AI solution landscape"
            class="h-full w-full object-contain p-4"
            loading="eager"
          />
        </div>

        <!-- Bottom panel: scrollable text area -->
        <article class="scroll-box h-[560px] overflow-y-auto rounded-3xl border border-slate-200 bg-white p-8 shadow-sm sm:p-10 lg:h-[680px]">
          <h2 class="mt-4 text-xl font-semibold tracking-[-0.03em] text-[#06142f]">
            Text
          </h2>

          <div class="mt-6 space-y-4 text-sm leading-6 text-slate-700">
            <p>
              Add your explanation of AI solution types here.
            </p>

            <h3 class="pt-4 text-xl font-semibold tracking-[-0.02em] text-[#06142f]">
              Example Section
            </h3>

            <p>
              This bottom panel is scrollable. Once your explanation becomes
              longer than the panel height, users can scroll inside this card.
            </p>

            <p>
              You can use this area to explain the Generative AI solution
              landscape, including chatbots, copilots, agents, RAG systems,
              workflow automation, fine-tuned models, and custom AI applications.
            </p>

            <p>
              Replace this placeholder content with your actual writing. The
              scroll behavior will stay the same.
            </p>

            <p>
              Add more content here to test scrolling. The page itself keeps the
              top image and bottom text box stacked vertically, while the bottom
              card handles its own scrolling.
            </p>

            <p>
              This is useful when you want the image to act like a reference
              diagram and the text panel to act like a detailed explanation area.
            </p>

            <p>
              Keep writing as much as you need. The card will preserve the same
              rounded, clean portfolio format.
            </p>

            <p>
              More placeholder text. More placeholder text. More placeholder text.
              More placeholder text. More placeholder text.
            </p>

            <p>
              More placeholder text. More placeholder text. More placeholder text.
              More placeholder text. More placeholder text.
            </p>

            <p>
              More placeholder text. More placeholder text. More placeholder text.
              More placeholder text. More placeholder text.
            </p>
          </div>
        </article>
      </div>

      <!-- Full-size image overlay -->
      <div
        id="image-lightbox"
        class="fixed inset-0 z-50 hidden cursor-zoom-out overflow-auto bg-black/90 p-4 sm:p-8"
        aria-hidden="true"
        role="button"
        tabindex="0"
        aria-label="Close full-size image"
        title="Click to close image"
      >
        <div class="flex min-h-full items-center justify-center">
          <img
            id="lightbox-image"
            src=""
            alt="Full-size generative AI solution landscape"
            class="max-w-none cursor-zoom-out rounded-2xl bg-white"
          />
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const imageBlock = document.querySelector('[data-full-image]');
  const lightbox = document.querySelector('#image-lightbox');
  const lightboxImage = document.querySelector('#lightbox-image');

  const openLightbox = () => {
    if (!(imageBlock instanceof HTMLElement)) return;
    if (!(lightbox instanceof HTMLElement)) return;
    if (!(lightboxImage instanceof HTMLImageElement)) return;

    const imageUrl = imageBlock.dataset.fullImage;
    if (!imageUrl) return;

    lightboxImage.src = imageUrl;
    lightbox.classList.remove('hidden');
    lightbox.setAttribute('aria-hidden', 'false');
    imageBlock.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeLightbox = () => {
    if (!(imageBlock instanceof HTMLElement)) return;
    if (!(lightbox instanceof HTMLElement)) return;
    if (!(lightboxImage instanceof HTMLImageElement)) return;

    lightbox.classList.add('hidden');
    lightbox.setAttribute('aria-hidden', 'true');
    lightboxImage.src = '';
    imageBlock.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  imageBlock?.addEventListener('click', openLightbox);

  imageBlock?.addEventListener('keydown', (event) => {
    if (!(event instanceof KeyboardEvent)) return;

    if (event.key === 'Enter' || event.key === ' ') {
      event.preventDefault();
      openLightbox();
    }
  });

  lightbox?.addEventListener('click', closeLightbox);

  lightbox?.addEventListener('keydown', (event) => {
    if (!(event instanceof KeyboardEvent)) return;

    if (event.key === 'Enter' || event.key === ' ') {
      event.preventDefault();
      closeLightbox();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeLightbox();
    }
  });
</script>

<style>
  .scroll-box {
    scrollbar-width: thin;
    scrollbar-color: #2563eb #e2e8f0;
  }

  .scroll-box::-webkit-scrollbar {
    width: 10px;
  }

  .scroll-box::-webkit-scrollbar-track {
    background: #e2e8f0;
    border-radius: 999px;
  }

  .scroll-box::-webkit-scrollbar-thumb {
    background: #2563eb;
    border-radius: 999px;
  }
</style>
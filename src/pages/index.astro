---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';

const iconPaths = {
  brain: 'M12 4.75c-1.38 0-2.5 1.12-2.5 2.5v.25H9a2.5 2.5 0 0 0-2.5 2.5v.25H6A2.5 2.5 0 0 0 3.5 12.75v.5A2.5 2.5 0 0 0 6 15.75h.5V16A2.5 2.5 0 0 0 9 18.5h.5v.25a2.5 2.5 0 0 0 5 0V18.5h.5A2.5 2.5 0 0 0 17.5 16v-.25h.5a2.5 2.5 0 0 0 2.5-2.5v-.5a2.5 2.5 0 0 0-2.5-2.5h-.5V10A2.5 2.5 0 0 0 15 7.5h-.5v-.25A2.5 2.5 0 0 0 12 4.75Zm0 0v14m-2.5-11.5H9m5.5 0h.5m-8.5 3H6m12 0h-.5m-11 5H6m12 0h-.5m-8 2.75H9m5.5 0h.5',
  target: 'M12 21a9 9 0 1 0-9-9 9 9 0 0 0 9 9Zm0-4.5A4.5 4.5 0 1 0 7.5 12 4.5 4.5 0 0 0 12 16.5Zm0-3a1.5 1.5 0 1 0-1.5-1.5A1.5 1.5 0 0 0 12 13.5Zm4.5-7.5 3-3m-1 0h1v1',
  cube: 'M12 3.75 4.5 7.875v8.25L12 20.25l7.5-4.125v-8.25L12 3.75Zm0 8.25 7.5-4.125M12 12 4.5 7.875M12 12v8.25',
} as const;

type IconName = keyof typeof iconPaths;

const sections: {
  title: string;
  subtitle: string;
  icon: IconName;
  links: {
    label: string;
    href: string;
  }[];
}[] = [
  {
    title: 'AI Understanding',
    subtitle: 'Foundations and AI Research',
    icon: 'brain',
    links: [
      { label: 'Transformer Basics: So What?', href: '/ai/transformer-basics' },
      { label: 'AI Research Papers & Takeaways', href: '/ai/research-papers' },
      { label: 'AI Solution Types', href: '/ai/ai-solution-types' },
    ],
  },
  {
    title: 'MarTech & AI',
    subtitle: 'Strategy and Opportunity',
    icon: 'target',
    links: [
      { label: 'MarTech 2026 Landscape', href: '/martech/landscape-2026' },
      { label: 'MarTech AI Opportunity', href: '/martech/opportunity' },
      { label: 'MarTech AI Value Creation', href: '/martech/value-creation' },
    ],
  },
  {
    title: 'AI Projects',
    subtitle: 'Agentic AI & RAG Demos',
    icon: 'cube',
    links: [
      { label: 'MarTech Vendor Evaluation Agent', href: '/projects/vendor-evaluation-agent' },
      { label: 'MarTech Content Evaluator Agent', href: '/projects/content-evaluator-agent' },
      { label: 'Chat with Me', href: '/projects/chat-with-me' },
    ],
  },
];
---

<Layout
  title="Home | Saurav Tripathy"
  description="AI strategy, MarTech transformation, and agentic AI portfolio by Saurav Tripathy."
>
  <SiteHeader />

  <main class="relative min-h-screen overflow-hidden bg-[#f8fbff] text-[#06142f]">
    <!-- Background pattern -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute right-[-12rem] top-32 h-[34rem] w-[52rem] rounded-full bg-blue-100/50 blur-3xl"></div>
      <div class="absolute right-0 top-40 hidden h-[30rem] w-[46rem] opacity-40 lg:block">
        <div class="h-full w-full bg-[radial-gradient(circle_at_center,#2563eb_1px,transparent_1.5px)] bg-[length:28px_28px]"></div>
      </div>
      <div class="absolute right-[-8rem] top-[21rem] hidden h-72 w-[58rem] rotate-[-8deg] rounded-[100%] border border-blue-200/60 lg:block"></div>
      <div class="absolute right-[-10rem] top-[23rem] hidden h-72 w-[58rem] rotate-[-5deg] rounded-[100%] border border-blue-200/40 lg:block"></div>
      <div class="absolute right-[-12rem] top-[25rem] hidden h-72 w-[58rem] rotate-[-2deg] rounded-[100%] border border-blue-200/30 lg:block"></div>
    </div>

    <section class="relative mx-auto max-w-7xl px-6 pb-20 pt-20 sm:px-8 lg:px-10 lg:pb-28 lg:pt-24">
      <!-- Hero -->
<div class="max-w-none -mt-8 lg:-mt-12">
  <p class="text-2xl font-semibold tracking-[-0.02em] text-slate-600 sm:text-3xl lg:text-4xl">
    Welcome to my portfolio.
  </p>

  <h1 class="mt-5 max-w-none text-3xl font-semibold leading-[1.08] tracking-[-0.045em] text-[#06142f] sm:text-4xl lg:text-5xl xl:text-6xl">
    I’m passionate about using AI to modernize enterprise processes by connecting strategic problem-solving, product thinking, and efficient execution.
  </h1>

  <div class="mt-5 flex flex-wrap items-center gap-4 text-lg font-medium text-slate-600 sm:text-xl lg:text-2xl">
    <span>Have feedback or ideas? Get in touch.</span>

    <a
      href="https://www.linkedin.com/in/sauravtripathy/"
      target="_blank"
      rel="noreferrer"
      aria-label="LinkedIn"
      class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-blue-200 bg-white text-[#0a66c2] shadow-sm transition hover:-translate-y-0.5 hover:border-blue-400 hover:shadow-md"
    >
      <svg
        viewBox="0 0 24 24"
        fill="currentColor"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.5 8h4V23h-4V8Zm7.5 0h3.83v2.05h.05c.53-1 1.84-2.05 3.78-2.05 4.04 0 4.79 2.66 4.79 6.12V23h-4v-7.88c0-1.88-.03-4.29-2.61-4.29-2.62 0-3.02 2.05-3.02 4.16V23h-4V8Z" />
      </svg>
    </a>

    <a
      href="mailto:sauravtripathy@yahoo.com"
      aria-label="Email"
      class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-blue-200 bg-white text-[#06142f] shadow-sm transition hover:-translate-y-0.5 hover:border-blue-400 hover:shadow-md"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-5 w-5"
        aria-hidden="true"
      >
        <path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" />
        <path d="m22 6-10 7L2 6" />
      </svg>
    </a>
  </div>
</div>

      <!-- Cards -->
      <div class="mt-12 grid gap-7 lg:mt-16 lg:grid-cols-3">
        {
          sections.map((section) => (
            <article class="group relative overflow-hidden rounded-3xl border border-blue-300/20 bg-gradient-to-br from-[#031943] via-[#073b8f] to-[#0059c8] p-8 shadow-2xl shadow-blue-950/20 transition duration-300 hover:-translate-y-1 hover:shadow-blue-950/30">
              <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(96,165,250,0.35),transparent_32rem)]"></div>
              <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-[#03112d]/80 to-transparent"></div>

              <div class="relative">
                <div class="flex h-16 w-16 items-center justify-center rounded-full border border-blue-300/35 bg-blue-500/10 text-blue-200">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-8 w-8"
                    aria-hidden="true"
                  >
                    <path d={iconPaths[section.icon]} />
                  </svg>
                </div>

                <h2 class="mt-8 text-4xl font-semibold tracking-[-0.04em] text-white">
                  {section.title}
                </h2>

                <p class="mt-3 text-lg text-white">
                  {section.subtitle}
                </p>

                <div class="my-7 h-px w-full bg-blue-200/30"></div>

                <div class="space-y-4">
                  {section.links.map((link) => (
                    <a
                      href={link.href}
                      class="flex items-center justify-between gap-4 rounded-2xl py-1 text-base font-medium text-white transition hover:text-blue-100"
                    >
                      <span class="flex items-center gap-4">
                        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/15 text-white">
                          →
                        </span>
                        <span>{link.label}</span>
                      </span>

                      <span class="text-2xl leading-none text-white transition group-hover:translate-x-1">
                        ›
                      </span>
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
---
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const title = "AI in MarTech, the Decoder's Brief";
const description = 'MarTech AI moves fast. Read the no-jargon guide to what’s new—and why it matters.';

type Concept = {
  name?: string;
  gloss?: string;
};

type Story = {
  num?: string;
  src?: string;
  fresh?: boolean;
  head?: string;
  url?: string;
  plain?: string;
  chips?: string[];
};

type Theme = {
  num?: string;
  head?: string;
  url?: string;
  body?: string[];
  ev?: [string, string][];
};

type NewsData = {
  generatedAt?: string;
  sourcesScanned?: number;
  surfaced?: number;
  concepts?: Record<string, Concept>;
  windows?: {
    day?: { stories?: Story[] };
    week?: { stories?: Story[] };
    month?: { themes?: Theme[] };
  };
};

const emptyNewsData: NewsData = {
  generatedAt: new Date().toISOString(),
  sourcesScanned: 0,
  surfaced: 0,
  concepts: {},
  windows: {
    day: { stories: [] },
    week: { stories: [] },
    month: { themes: [] },
  },
};

let newsData: NewsData = emptyNewsData;

try {
  const p = fileURLToPath(new URL('../../../public/martech-news.json', import.meta.url));
  newsData = JSON.parse(readFileSync(p, 'utf8')) as NewsData;
} catch {
  newsData = emptyNewsData;
}

const dayStories = newsData.windows?.day?.stories ?? [];
const weekStories = newsData.windows?.week?.stories ?? [];
const monthThemes = newsData.windows?.month?.themes ?? [];

const windows = [
  {
    id: 'day',
    name: 'Last 24 hours',
    count: `${dayStories.length} items`,
    mode: 'What actually dropped',
  },
  {
    id: 'week',
    name: 'Past week',
    count: `${weekStories.length} items`,
    mode: 'What held up past the news cycle',
  },
  {
    id: 'month',
    name: 'Past month',
    count: `${monthThemes.length} themes`,
    mode: 'Themes underneath the headlines',
  },
] as const;

const wd = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
const mo = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const gd = new Date(newsData.generatedAt ?? Date.now());
const editionLabel = `${wd[gd.getUTCDay()]} ${String(gd.getUTCDate()).padStart(2, '0')} ${mo[gd.getUTCMonth()]} ${gd.getUTCFullYear()}`;

const escapeHtml = (value: unknown) =>
  String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');

const decodeInlineEntities = (value: unknown) =>
  String(value ?? '')
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#39;|&#x27;/g, "'");

const formatInline = (value: unknown) =>
  escapeHtml(decodeInlineEntities(value))
    .replace(/&lt;(\/?)(?:b|strong)&gt;/gi, '<$1strong>')
    .replace(/&lt;(\/?)em&gt;/gi, '<$1em>')
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\n/g, '<br />');

const getStoriesForWindow = (id: string) => {
  if (id === 'day') return dayStories;
  if (id === 'week') return weekStories;
  return [];
};

const getConcept = (id: string) => newsData.concepts?.[id] ?? { name: id, gloss: '' };
---

<Layout title={`${title} | Saurav Tripathy`} description={description} showFooterCta={false}>
  <SiteHeader />

  <main class="decoder-page">
    <section class="decoder-shell" aria-labelledby="decoder-title">
      <header class="decoder-masthead">
        <h1 id="decoder-title">AI in MarTech, the <em>Decoder’s Brief</em></h1>
        <p class="thesis">{description}</p>

        <div class="dateline">
          <span>EDITION — <b>{editionLabel}</b></span>
        </div>
      </header>

      <div class="windows" role="tablist" aria-label="Time window">
        {windows.map((w, i) => (
          <button
            class="win"
            role="tab"
            id={`tab-${w.id}`}
            aria-controls={`panel-${w.id}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            data-win={w.id}
            type="button"
          >
            <span class="wname">{w.name} <span class="wcount">{w.count}</span></span>
            {w.mode && <span class="wmode">{w.mode}</span>}
          </button>
        ))}
      </div>

      {windows.map((w, i) => (
        <section
          class="panel"
          id={`panel-${w.id}`}
          role="tabpanel"
          aria-labelledby={`tab-${w.id}`}
          data-panel={w.id}
          hidden={i !== 0}
        >
          {w.id === 'month' ? (
            <div class="synth">
              {monthThemes.map((theme) => (
                <article class="theme-card">
                  <div class="tnum">{theme.num}</div>
                  <h2>
                    <a href={theme.url} target="_blank" rel="noopener noreferrer">
                      <span set:html={formatInline(theme.head)}></span>
                    </a>
                  </h2>

                  {(theme.body ?? []).map((paragraph) => (
                    <p set:html={formatInline(paragraph)}></p>
                  ))}

                  {(theme.ev ?? []).length > 0 && (
                    <div class="evidence">
                      <span class="elabel">Articles</span>
                      {(theme.ev ?? []).map((item) => (
                        <a href={item[1]} target="_blank" rel="noopener noreferrer">
                          {item[0]}
                        </a>
                      ))}
                    </div>
                  )}
                </article>
              ))}
            </div>
          ) : (
            <div class="story-feed">
              {getStoriesForWindow(w.id).map((story) => (
                <article class="story-card">
                  <div class="story-news">
                    <div class="story-num">{story.num}</div>
                    <div class="story-source">
                      <span>{story.src}</span>
                      {story.fresh && <span class="fresh">Fresh</span>}
                    </div>
                    <h2 class="story-head">
                      <a href={story.url} target="_blank" rel="noopener noreferrer">
                        <span set:html={formatInline(story.head)}></span>
                      </a>
                    </h2>
                    <a class="read-source" href={story.url} target="_blank" rel="noopener noreferrer">
                      Read source →
                    </a>
                  </div>

                  <div class="story-plain">
                    <div class="plain-label">In plain English</div>
                    <p class="plain-copy" set:html={formatInline(story.plain)}></p>

                    {(story.chips ?? []).length > 0 && (
                      <div class="needs">
                        <div class="needs-label">To follow this article, you need to know:</div>
                        <div class="chips">
                          {(story.chips ?? []).map((id) => {
                            const concept = getConcept(id);
                            return (
                              <span class="chip" title={concept.gloss ?? ''}>{concept.name ?? id}</span>
                            );
                          })}
                        </div>
                      </div>
                    )}
                  </div>
                </article>
              ))}
            </div>
          )}
        </section>
      ))}
    </section>
  </main>
</Layout>

<style>
  .decoder-page {
    --paper: #f1f0eb;
    --ink: #11100d;
    --muted: #7f7a70;
    --soft: #4b4740;
    --line: #d7d1c4;
    --line-strong: #c6beae;
    --accent: #9b6411;
    --teal: #004f5f;
    --chip-bg: #f6f4ef;
    --mono: var(--font-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace);
    --serif: ui-serif, Georgia, Cambria, 'Times New Roman', Times, serif;

    min-height: 100vh;
    background: var(--paper);
    color: var(--ink);
    padding: clamp(2rem, 5vw, 4rem) 1rem 5rem;
  }

  .decoder-shell {
    max-width: 76rem;
    margin: 0 auto;
  }

  .decoder-masthead {
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--line-strong);
  }

  .dateline,
  .wcount,
  .wmode,
  .story-num,
  .story-source,
  .read-source,
  .plain-label,
  .needs-label,
  .chip,
  .tnum,
  .elabel {
    font-family: var(--mono);
  }


  .decoder-masthead h1 {
    margin: 0;
    max-width: none;
    font-family: var(--serif);
    font-size: clamp(1.75rem, 4.4vw, 3.05rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 1;
    white-space: nowrap;
  }

  .decoder-masthead em {
    color: var(--teal);
    font-style: italic;
  }

  .thesis {
    margin: 0.75rem 0 0;
    max-width: none;
    color: var(--soft);
    font-size: clamp(0.86rem, 1.5vw, 1rem);
    line-height: 1.45;
    white-space: nowrap;
  }

  .dateline {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 1rem;
    margin-top: 1.25rem;
    color: var(--muted);
    font-size: 0.68rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .dateline b {
    color: var(--soft);
    font-weight: 700;
  }


  .windows {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-bottom: 1px solid var(--line);
  }

  .win {
    appearance: none;
    border: 0;
    border-right: 1px solid var(--line);
    background: transparent;
    cursor: pointer;
    padding: 1rem 0.9rem 0.95rem;
    text-align: left;
  }

  .win:last-child {
    border-right: 0;
  }

  .win[aria-selected='true'] {
    background: #ece9e1;
  }

  .wname {
    display: block;
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1;
  }

  .wcount {
    margin-left: 0.25rem;
    color: var(--muted);
    font-size: 0.62rem;
    font-weight: 500;
  }

  .wmode {
    display: block;
    margin-top: 0.35rem;
    color: var(--muted);
    font-size: 0.62rem;
    line-height: 1.35;
  }

  .story-card {
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(0, 1fr);
    border-bottom: 1px solid var(--line);
  }

  .story-news {
    padding: 1.55rem 2.1rem 1.55rem 0;
    border-right: 1px dotted var(--line-strong);
  }

  .story-plain {
    padding: 1.55rem 0 1.55rem 2.1rem;
  }

  .story-num {
    color: var(--accent);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .story-source {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
    color: var(--muted);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
  }

  .fresh {
    display: inline-flex;
    align-items: center;
    border-radius: 2px;
    background: var(--accent);
    color: #fff;
    padding: 0.14rem 0.38rem;
    font-size: 0.55rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .story-head {
    margin: 0.75rem 0 1.25rem;
    font-family: var(--serif);
    font-size: clamp(1.2rem, 3vw, 1.42rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.15;
  }

  .story-head a,
  .theme-card h2 a {
    color: inherit;
    text-decoration: none;
  }

  .story-head a:hover,
  .theme-card h2 a:hover {
    color: var(--teal);
  }

  .read-source {
    color: var(--teal);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    text-decoration: none;
  }

  .read-source:hover {
    color: var(--accent);
  }

  .plain-label {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--teal);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .plain-label::before {
    content: '';
    width: 17px;
    height: 1px;
    background: var(--teal);
  }

  .plain-copy {
    margin: 0.75rem 0 0;
    color: var(--ink);
    font-size: 0.98rem;
    line-height: 1.52;
  }

  .plain-copy strong {
    font-weight: 800;
  }

  .needs {
    margin-top: 1.15rem;
  }

  .needs-label {
    margin-bottom: 0.5rem;
    color: var(--muted);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .chip {
    border: 1px solid var(--line-strong);
    background: var(--chip-bg);
    color: var(--soft);
    padding: 0.27rem 0.55rem;
    font-size: 0.68rem;
    line-height: 1;
    cursor: help;
  }

  .chip:hover {
    border-color: var(--teal);
    color: var(--teal);
  }

  .synth {
    padding-top: 1.5rem;
  }


  .theme-card {
    border-top: 1px solid var(--line);
    padding: 1.4rem 0;
  }

  .theme-card:first-of-type {
    border-top: 0;
    padding-top: 0.25rem;
  }

  .tnum {
    color: var(--muted);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
  }

  .theme-card h2 {
    margin: 0.45rem 0 0.7rem;
    font-family: var(--serif);
    font-size: clamp(1.45rem, 4vw, 2rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
  }

  .theme-card p {
    margin: 0;
    color: var(--soft);
    font-size: 0.98rem;
    line-height: 1.58;
  }

  .theme-card p + p {
    margin-top: 0.7rem;
  }

  .evidence {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    margin-top: 1rem;
    font-family: var(--mono);
    font-size: 0.68rem;
  }

  .elabel {
    margin-right: 0.25rem;
    color: var(--muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .evidence a {
    border: 1px solid var(--line-strong);
    color: var(--teal);
    padding: 0.2rem 0.5rem;
    text-decoration: none;
  }

  .evidence a:hover {
    border-color: var(--teal);
  }

  @media (max-width: 640px) {
    .decoder-page {
      padding-inline: 1rem;
    }

    .dateline {
      align-items: flex-start;
      flex-direction: column;
    }

    .decoder-masthead h1,
    .thesis {
      white-space: normal;
    }

    .decoder-masthead h1 {
      font-size: clamp(1.45rem, 7vw, 2rem);
      letter-spacing: -0.045em;
    }

    .thesis {
      font-size: clamp(0.72rem, 3vw, 0.88rem);
    }

    .windows {
      grid-template-columns: 1fr;
    }

    .win {
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .story-card {
      grid-template-columns: 1fr;
    }

    .story-news {
      border-right: 0;
      border-bottom: 1px dotted var(--line-strong);
      padding: 1.4rem 0 1.15rem;
    }

    .story-plain {
      padding: 1.15rem 0 1.5rem;
    }
  }
</style>

<script>
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-win]'));
  const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-panel]'));

  function activate(id: string): void {
    tabs.forEach((tab) => {
      tab.setAttribute('aria-selected', String(tab.dataset.win === id));
    });

    panels.forEach((panel) => {
      panel.hidden = panel.dataset.panel !== id;
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.win;
      if (id) activate(id);
    });

    tab.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
      event.preventDefault();

      const index = tabs.indexOf(tab);
      const nextIndex = event.key === 'ArrowRight'
        ? (index + 1) % tabs.length
        : (index - 1 + tabs.length) % tabs.length;

      const nextTab = tabs[nextIndex];
      if (!nextTab) return;

      nextTab.focus();

      const id = nextTab.dataset.win;
      if (id) activate(id);
    });
  });
</script>

---
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const title = "AI in MarTech AI, the Decoder's Brief";
const description = 'MarTech AI moves fast. Read the no-jargon guide to what’s new—and why it matters.';

// Read the agent's output at build time. The same file is served at /martech-news.json
// so the in-page Refresh button can re-fetch (or re-run) it client-side.
let newsData: any;
try {
  const p = fileURLToPath(new URL('../../../public/martech-news.json', import.meta.url));
  newsData = JSON.parse(readFileSync(p, 'utf8'));
} catch {
  newsData = { generatedAt: new Date().toISOString(), sourcesScanned: 0, surfaced: 0, concepts: {}, windows: { day: { stories: [] }, week: { stories: [] }, month: { themes: [], takeaway: '' } } };
}

const windows = [
  { id: 'day', label: 'Window 01', name: 'Last 24 hours', count: '5 items', mode: 'What actually dropped' },
  { id: 'week', label: 'Window 02', name: 'Past week', count: '5 items', mode: 'What held up past the news cycle' },
  { id: 'month', label: 'Window 03', name: 'Past month', count: '5 themes', mode: 'The themes underneath the headlines' },
];

const wd = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
const mo = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const gd = new Date(newsData.generatedAt ?? Date.now());
const editionLabel = `${wd[gd.getUTCDay()]} ${String(gd.getUTCDate()).padStart(2, '0')} ${mo[gd.getUTCMonth()]} ${gd.getUTCFullYear()}`;
---

<Layout title={`${title} | Saurav Tripathy`} description={description}>
  <SiteHeader />

  <main class="decoder min-h-screen bg-[#f8fbff] px-6 py-16 text-[#06142f]">
    <section class="mx-auto max-w-5xl">

      <!-- Masthead -->
      <header class="border-b-2 border-[#06142f] pb-6">
        <h1 class="dh1">AI in MarTech, the <em>Decoder’s Brief</em></h1>
        <p class="thesis">
          MarTech AI moves fast. Read the no-jargon guide to what’s new—and why it matters.
        </p>
        <div class="dateline">
          <span class="ed">
            EDITION — <b id="edition">{editionLabel}</b> &nbsp;/&nbsp;
            Sources scanned: <b id="scanned">{newsData.sourcesScanned}</b> &nbsp;/&nbsp;
            Surfaced: <b id="surfaced">{newsData.surfaced}</b>
          </span>
          <button class="refresh" id="refresh" type="button" aria-label="Refresh the brief">
            <svg class="ricon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 12a9 9 0 1 1-2.64-6.36" /><path d="M21 3v6h-6" />
            </svg>
            <span class="rtext">Refresh</span>
          </button>
        </div>
      </header>

      <!-- Window selector -->
      <div class="windows" role="tablist" aria-label="Time window">
        {windows.map((w, i) => (
          <button
            class="win"
            role="tab"
            id={`tab-${w.id}`}
            aria-controls={`panel-${w.id}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            data-win={w.id}
          >
            <span class="wlabel">{w.label}</span>
            <span class="wname">{w.name} <span class="wcount">{w.count}</span></span>
            <span class="wmode">{w.mode}</span>
          </button>
        ))}
      </div>

      <!-- Panels (filled client-side from the agent's JSON) -->
      {windows.map((w, i) => (
        <section class="panel" id={`panel-${w.id}`} role="tabpanel" aria-labelledby={`tab-${w.id}`} hidden={i !== 0}></section>
      ))}

    </section>
  </main>
</Layout>

<style>
  .decoder {
    --d-ink: #06142f;
    --d-soft: #475569;
    --d-faint: #7c879b;
    --d-line: #dbe3ef;
    --d-line-strong: #c3cede;
    --d-blue: #1d4ed8;
    --d-blue-deep: #1e3a8a;
    --d-blue-wash: #e8effe;
    --d-amber: #b45309;
    --d-card: #ffffff;
    --d-mono: var(--font-mono);
  }
  .decoder em { font-style: italic; color: var(--d-blue); }

  .dh1 { margin: 0 0 4px; font-size: clamp(2.4rem, 5.4vw, 4rem); line-height: 1.02; letter-spacing: -0.045em; font-weight: 800; }
  .thesis { margin: 0.75rem 0 0; max-width: 42rem; font-size: clamp(1.05rem, 2vw, 1.3rem); line-height: 1.4; color: var(--d-soft); }

  .dateline {
    margin: 1.5rem 0 0;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
  }
  .ed { font-family: var(--d-mono); font-size: 0.72rem; letter-spacing: 0.04em; color: var(--d-faint); }
  .ed b { color: var(--d-soft); font-weight: 600; }

  .refresh {
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.4rem 0.8rem;
    font-family: var(--d-mono); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.04em;
    color: var(--d-blue); background: #fff;
    border: 1px solid var(--d-line-strong); border-radius: 999px;
    cursor: pointer; transition: all 150ms ease;
  }
  .refresh:hover { border-color: var(--d-blue); background: var(--d-blue-wash); }
  .refresh:disabled { opacity: 0.6; cursor: progress; }
  .refresh .ricon { width: 13px; height: 13px; }
  .refresh.spin .ricon { animation: rspin 0.8s linear infinite; }
  @keyframes rspin { to { transform: rotate(360deg); } }

  /* Window selector */
  .windows { display: grid; grid-template-columns: repeat(3, 1fr); border-bottom: 1px solid var(--d-line-strong); }
  .win { cursor: pointer; text-align: left; padding: 1.15rem 1.25rem 1rem; border-right: 1px solid var(--d-line); background: none; position: relative; transition: background 160ms ease; }
  .win:last-child { border-right: none; }
  .win:hover { background: #eef3fb; }
  .win[aria-selected='true'] { background: var(--d-card); }
  .win[aria-selected='true']::after { content: ''; position: absolute; left: 0; right: 0; bottom: -1px; height: 3px; background: var(--d-blue); }
  .wlabel { display: block; font-family: var(--d-mono); font-size: 0.68rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--d-faint); font-weight: 500; }
  .win[aria-selected='true'] .wlabel { color: var(--d-blue); }
  .wname { display: flex; align-items: baseline; gap: 0.55rem; margin-top: 0.4rem; font-size: clamp(1.25rem, 2.4vw, 1.6rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1; }
  .wcount { font-family: var(--d-mono); font-size: 0.72rem; color: var(--d-faint); font-weight: 500; }
  .wmode { display: block; margin-top: 0.5rem; font-size: 0.78rem; color: var(--d-soft); white-space: nowrap; }

  /* Story card */
  .story { display: grid; grid-template-columns: 1.05fr 1fr; border-bottom: 1px solid var(--d-line); }
  .col-news { border-right: 1px dotted var(--d-line-strong); padding: 1.5rem 2.25rem 1.6rem 0; }
  .col-plain { padding: 1.5rem 0 1.6rem 2.25rem; }
  .snum { font-family: var(--d-mono); font-size: 0.7rem; color: var(--d-amber); letter-spacing: 0.1em; font-weight: 600; }
  .ssrc { margin-top: 0.2rem; font-family: var(--d-mono); font-size: 0.7rem; color: var(--d-faint); letter-spacing: 0.04em; display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; }
  .fresh { background: var(--d-amber); color: #fff; font-size: 0.56rem; padding: 0.12rem 0.4rem; border-radius: 2px; letter-spacing: 0.1em; font-weight: 700; }
  .shead { margin: 0.6rem 0 0.75rem; font-size: 1.3rem; line-height: 1.18; letter-spacing: -0.02em; font-weight: 700; }
  .shead a { color: var(--d-ink); text-decoration: none; background-image: linear-gradient(var(--d-blue), var(--d-blue)); background-size: 0% 1.5px; background-position: 0 100%; background-repeat: no-repeat; transition: background-size 250ms ease; }
  .shead a:hover { background-size: 100% 1.5px; color: var(--d-blue-deep); }
  .sread { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--d-mono); font-size: 0.7rem; font-weight: 500; letter-spacing: 0.04em; color: var(--d-blue); text-decoration: none; }
  .sread svg { width: 11px; height: 11px; }
  .sread:hover { color: var(--d-amber); }
  .plabel { display: flex; align-items: center; gap: 0.45rem; margin-bottom: 0.55rem; font-family: var(--d-mono); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--d-blue); }
  .plabel::before { content: ''; width: 14px; height: 1.5px; background: var(--d-blue); }
  .plain { font-size: 0.95rem; line-height: 1.55; color: var(--d-ink); }
  .plain b { font-weight: 600; }
  .needs { margin-top: 1rem; }
  .nlabel { margin-bottom: 0.5rem; font-family: var(--d-mono); font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--d-faint); }
  .chips { display: flex; flex-wrap: wrap; gap: 0.375rem; }
  .chip { font-family: var(--d-mono); font-size: 0.7rem; padding: 0.25rem 0.55rem; border: 1px solid var(--d-line-strong); border-radius: 2px; color: var(--d-soft); background: #fff; cursor: help; transition: all 150ms ease; }
  .chip:hover { border-color: var(--d-blue); color: var(--d-blue); background: var(--d-blue-wash); }

  /* Synthesis (month) */
  .synth { padding: 1.6rem 0 0; }
  .skicker { margin-bottom: 0.9rem; font-family: var(--d-mono); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--d-amber); }
  .theme { border-top: 1px solid var(--d-line); padding: 1.5rem 0; }
  .theme:first-of-type { border-top: none; padding-top: 0.4rem; }
  .tnum { font-family: var(--d-mono); font-size: 0.7rem; color: var(--d-faint); }
  .theme h3 { margin: 0.4rem 0 0.65rem; font-size: 1.55rem; line-height: 1.12; letter-spacing: -0.02em; font-weight: 700; }
  .theme h3 a { color: var(--d-ink); text-decoration: none; background-image: linear-gradient(var(--d-blue), var(--d-blue)); background-size: 0% 1.5px; background-position: 0 100%; background-repeat: no-repeat; transition: background-size 250ms ease; }
  .theme h3 a:hover { background-size: 100% 1.5px; }
  .theme p { margin: 0; max-width: 70ch; font-size: 0.95rem; line-height: 1.58; color: var(--d-soft); }
  .theme p + p { margin-top: 0.65rem; }
  .evidence { margin-top: 0.95rem; display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem 0; font-family: var(--d-mono); font-size: 0.72rem; }
  .elabel { margin-right: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--d-faint); }
  .evidence a { margin-right: 0.45rem; padding: 0.2rem 0.6rem; border: 1px solid var(--d-line-strong); border-radius: 2px; color: var(--d-blue); text-decoration: none; transition: all 150ms ease; }
  .evidence a:hover { border-color: var(--d-blue); background: var(--d-blue-wash); }
  .takeaway { margin-top: 2rem; border: 1px solid var(--d-blue); background: var(--d-blue-wash); border-radius: 4px; padding: 1.35rem 1.5rem; }
  .tlabel { margin-bottom: 0.5rem; font-family: var(--d-mono); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--d-blue-deep); }
  .takeaway p { margin: 0; font-size: 1.2rem; line-height: 1.4; font-weight: 600; }

  @media (max-width: 760px) {
    .story { grid-template-columns: 1fr; }
    .col-news { border-right: none; border-bottom: 1px dotted var(--d-line-strong); padding: 1.4rem 0 1.1rem; }
    .col-plain { padding: 1.1rem 0 1.5rem; }
  }
  @media (max-width: 560px) {
    .windows { grid-template-columns: 1fr; }
    .win { border-right: none; border-bottom: 1px solid var(--d-line); }
    .win[aria-selected='true']::after { display: none; }
    .win[aria-selected='true'] { border-left: 3px solid var(--d-blue); }
  }
</style>

<script define:vars={{ initialData: newsData }}>
  // ─────────────────────────────────────────────────────────────────────────
  // CONNECT THE LIVE AGENT HERE (optional).
  // Leave empty  → Refresh re-fetches the latest committed run (/martech-news.json),
  //                which the daily GitHub Action keeps up to date.
  // Set a URL    → Refresh calls your deployed agent API and re-runs it live.
  //                e.g. "https://sauravtripathy-martech-news-agent.hf.space/refresh"
  const REFRESH_ENDPOINT = '';
  // ─────────────────────────────────────────────────────────────────────────

  let data = initialData;
  const $ = (s) => document.querySelector(s);
  const esc = (v) => String(v ?? '');

  const ARROW =
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';

  function chip(id) {
    const c = (data.concepts || {})[id];
    const name = c ? c.name : id;
    const gloss = c ? c.gloss.replace(/"/g, '&quot;') : '';
    return `<span class="chip" title="${gloss}">${name}</span>`;
  }

  function storyCard(s) {
    return `<article class="story">
      <div class="col-news">
        <div class="snum">${esc(s.num)}</div>
        <div class="ssrc"><span>${esc(s.src)}</span>${s.fresh ? '<span class="fresh">FRESH</span>' : ''}</div>
        <h3 class="shead"><a href="${esc(s.url)}" target="_blank" rel="noopener">${esc(s.head)}</a></h3>
        <a class="sread" href="${esc(s.url)}" target="_blank" rel="noopener">Read source ${ARROW}</a>
      </div>
      <div class="col-plain">
        <div class="plabel">In plain English</div>
        <div class="plain">${esc(s.plain)}</div>
        <div class="needs">
          <div class="nlabel">To follow this, you need:</div>
          <div class="chips">${(s.chips || []).map(chip).join('')}</div>
        </div>
      </div>
    </article>`;
  }

  function themeCard(t) {
    const body = (t.body || []).map((p) => `<p>${p}</p>`).join('');
    const ev = (t.ev || []).map((e) => `<a href="${esc(e[1])}" target="_blank" rel="noopener">${esc(e[0])}</a>`).join('');
    return `<div class="theme">
      <div class="tnum">${esc(t.num)}</div>
      <h3><a href="${esc(t.url)}" target="_blank" rel="noopener">${t.head}</a></h3>
      ${body}
      <div class="evidence"><span class="elabel">Articles</span>${ev}</div>
    </div>`;
  }

  function renderPanel(win) {
    const panel = $(`#panel-${win}`);
    if (!panel) return;
    const w = (data.windows || {})[win] || {};
    if (win === 'month') {
      const themes = (w.themes || []).map(themeCard).join('');
      panel.innerHTML = `<div class="synth">
        ${themes}
        <div class="takeaway"><div class="tlabel">The one line to carry in</div><p>${w.takeaway || ''}</p></div>
      </div>`;
    } else {
      panel.innerHTML = (w.stories || []).map(storyCard).join('');
    }
  }

  function renderAll() {
    ['day', 'week', 'month'].forEach(renderPanel);
    const g = new Date(data.generatedAt || Date.now());
    const wd = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    const mo = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    const ed = $('#edition');
    if (ed) ed.textContent = `${wd[g.getUTCDay()]} ${String(g.getUTCDate()).padStart(2, '0')} ${mo[g.getUTCMonth()]} ${g.getUTCFullYear()}`;
    const sc = $('#scanned'); if (sc && data.sourcesScanned != null) sc.textContent = data.sourcesScanned;
    const su = $('#surfaced'); if (su && data.surfaced != null) su.textContent = data.surfaced;
  }

  function activate(id) {
    document.querySelectorAll('.win').forEach((t) => t.setAttribute('aria-selected', String(t.dataset.win === id)));
    document.querySelectorAll('.panel').forEach((p) => { p.hidden = p.id !== `panel-${id}`; });
  }

  const tabs = Array.from(document.querySelectorAll('.win'));
  tabs.forEach((t) => {
    t.addEventListener('click', () => activate(t.dataset.win));
    t.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
      e.preventDefault();
      const i = tabs.indexOf(t);
      const n = e.key === 'ArrowRight' ? (i + 1) % tabs.length : (i - 1 + tabs.length) % tabs.length;
      tabs[n].focus();
      activate(tabs[n].dataset.win);
    });
  });

  const btn = $('#refresh');
  btn?.addEventListener('click', async () => {
    btn.disabled = true;
    btn.classList.add('spin');
    try {
      const url = REFRESH_ENDPOINT || `/martech-news.json?t=${Date.now()}`;
      const res = await fetch(url, { method: REFRESH_ENDPOINT ? 'POST' : 'GET' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const fresh = await res.json();
      if (fresh && fresh.windows) {
        data = fresh;
        renderAll();
      }
    } catch (err) {
      console.error('Refresh failed:', err);
      btn.querySelector('.rtext').textContent = 'Retry';
    } finally {
      btn.disabled = false;
      btn.classList.remove('spin');
    }
  });

  renderAll();
</script>
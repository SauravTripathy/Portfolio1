</style>

<script>
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.win'));
  const panels = Array.from(document.querySelectorAll<HTMLElement>('.panel'));

  function activate(id: string) {
    tabs.forEach((t) => t.setAttribute('aria-selected', String(t.dataset.win === id)));
    panels.forEach((p) => {
      p.hidden = p.id !== `panel-${id}`;
    });
  }

  tabs.forEach((t) => {
    t.addEventListener('click', () => activate(t.dataset.win as string));
    t.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
      e.preventDefault();
      const i = tabs.indexOf(t);
      const next = e.key === 'ArrowRight' ? (i + 1) % tabs.length : (i - 1 + tabs.length) % tabs.length;
      tabs[next].focus();
      activate(tabs[next].dataset.win as string);
    });
  });
</script>
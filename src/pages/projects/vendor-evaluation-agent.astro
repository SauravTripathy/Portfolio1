---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const title = 'MarTech Vendor Evaluation Agent';
const description =
  'A LangGraph agent that runs a single-vendor MarTech deep-dive: gathers public evidence, scores it against a weighted rubric, enforces must-pass gates, and cross-checks with a second model.';

// TODO: replace these with your real links once the code repo / demo are live.
const codeHref = 'https://github.com/SauravTripathy/martech-vendor-agent';
const demoHref = 'https://huggingface.co/spaces/SauravTripathy/martech-vendor-agent'; // e.g. a Hugging Face Space URL

const nodes = [
  {
    n: '01',
    name: 'Evidence Gathering',
    body: 'User inputs MarTech vendor name and additional context and reports (if any). Agent uses Claude to scour publicly available data collating facts and evidence relevant to the predetermined rubric and scoring each criterion on a 1-5 evalscale',
  },
  {
    n: '02',
    name: 'Vendor Evaluation',
    body: 'Complied research is handed off to an OpenAI model that reviews and enriches the report as needed.',
  },
  {
    n: '03',
    name: 'Report Generation',
    body: 'Python backend populates a ready to use Excel for download and human review.',
  },
];

const decisions = [
  {
    name: 'Gates are control flow, not a field',
    body: 'A failed must-pass gate (no SOC 2, no EU residency) short-circuits the graph — the vendor is eliminated and the second-model pass is skipped to avoid spending tokens ranking a disqualified vendor.',
  },
  {
    name: 'Scores capped by evidence tier',
    body: 'A claim supported only by a vendor’s own marketing page cannot exceed 3/5. The ceiling is enforced in the prompt and again in code, so a public-source agent can’t award “best-in-class” off a brochure.',
  },
  {
    name: 'Consistency, not accuracy',
    body: 'With no ground truth, the agent measures model agreement rather than claiming accuracy. Non-evaluable criteria are left blank, never zero, so a data gap can’t silently sink a vendor.',
  },
];

const stack = ['Python', 'LangGraph', 'Anthropic API (researcher)', 'OpenAI API (judge)', 'Gradio'];
---

<Layout title={`${title} | Saurav Tripathy`} description={description}>
  <SiteHeader />

  <main class="min-h-screen bg-[#f8fbff] px-6 py-20 text-[#06142f]">
    <section class="mx-auto max-w-5xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">
        AI Projects
      </p>

      <h1 class="mt-4 text-5xl font-semibold tracking-[-0.04em]">
        {title}
      </h1>

      <p class="mt-6 max-w-3xl text-xl text-slate-600">
        AI research tool evaluating MarTech vendors against a pre-determined scorecard. <br><br> The agent gathers public evidence, scores it against a weighted rubric, and instantly generates an Excel report with scores and supporting evidence.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={codeHref}
          class="rounded-full border border-slate-300 px-6 py-3 text-sm font-semibold text-[#06142f] transition hover:border-blue-700 hover:text-blue-700"
        >
          View code
        </a>
        <a
          href={demoHref}
          class="rounded-full border border-slate-300 px-6 py-3 text-sm font-semibold text-[#06142f] transition hover:border-blue-700 hover:text-blue-700"
        >
          Live demo
        </a>
      </div>

      <!-- Overview -->
      <div class="mt-16 grid gap-10 md:grid-cols-3">
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-blue-700">
            Design
          </h2>
          <p class="mt-3 text-slate-600">Design &amp; Researcher-Judge pattern</p>
        </div>
    
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-blue-700">
            Stack
          </h2>
          <p class="mt-3 text-slate-600">{stack.join(' · ')}</p>
        </div>
      </div>

      <!-- How it works -->
      <div class="mt-16 border-t border-slate-200 pt-12">
        <h2 class="text-3xl font-semibold tracking-[-0.03em]">How it works</h2>
    
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {nodes.map((node) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-7">
              <p class="text-sm font-semibold tracking-[0.16em] text-blue-700">{node.n}</p>
              <h3 class="mt-3 text-xl font-semibold">{node.name}</h3>
              <p class="mt-3 text-slate-600">{node.body}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Design decisions -->
      <div class="mt-16 border-t border-slate-200 pt-12">
        <h2 class="text-3xl font-semibold tracking-[-0.03em]">Key design decisions</h2>
        <div class="mt-10 space-y-6">
          {decisions.map((d) => (
            <div class="rounded-2xl bg-white p-7 ring-1 ring-slate-200">
              <h3 class="text-xl font-semibold">{d.name}</h3>
              <p class="mt-3 max-w-3xl text-slate-600">{d.body}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Disclaimer -->
      <div class="mt-16 border-t border-slate-200 pt-12">
        <p class="max-w-3xl text-sm text-slate-500">
          Initial assessment from publicly available sources. Output is a decision
          aid, not an oracle: category subtotals and must-pass gates are designed
          to keep a high overall score from hiding a disqualifying gap.
        </p>
      </div>
    </section>
  </main>
</Layout>
---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const title = 'MarTech Vendor Evaluation Agent';
const description =
  'A LangGraph agent that runs a single-vendor MarTech deep-dive: gathers tiered public evidence, scores it against a weighted rubric with evidence-strength caps, and has a second model from a rival provider cross-examine the result.';

const excelHref = 'https://github.com/SauravTripathy/martech-vendor-agent/raw/main/MarTech_Vendor_Scorecard_Single.xlsx';
const codeHref = 'https://github.com/SauravTripathy/martech-vendor-agent';
const demoHref = 'https://sauravtripathy-martech-vendor-agent.hf.space';

const nodes = [
  {
    n: '01',
    name: 'Gather the evidence',
    body: 'You give the agent a vendor name, your use case, and any documents you already hold, e.g., analyst reports, RFP response, etc. It researches the vendor across public sources (product pages, analyst coverage, customer reviews, trust portals) and files every fact against the scorecard question it answers. Each fact is graded by how independent its source is, from "the vendor says so" up to "independently verifiable".',
  },
  {
    n: '02',
    name: 'Generate Scores',
    body: 'The agent scores the vendor 1–5 on 28 weighted criteria across eight categories — functional fit, integration, AI capability, security & compliance, three-year cost, vendor viability, lock-in risk, and implementation support. One honesty rule is built in: a claim backed only by the vendor\u2019s own marketing can never score above 3. Top marks must be earned with independent proof, and where evidence is missing the score stays blank rather than guessed.',
  },
  {
    n: '03',
    name: 'Cross-examine & report',
    body: 'A second AI from a different provider then plays judge. It re-reads the same evidence, challenges any score it can\u2019t defend, flags gaps worth asking the vendor about, and recommends adjustments. Everything lands in a ready-to-share Excel scorecard — the scores, the sources behind them, and the judge\u2019s dissent — so a human makes the final call with the full picture in front of them.',
  },
];

const stack = ['Python', 'LangGraph', 'Anthropic API (researcher)', 'OpenAI API (judge)', 'Gradio'];
---

<Layout title={`${title} | Saurav Tripathy`} description={description}>
  <SiteHeader />

  <main class="min-h-screen bg-[#f8fbff] px-6 py-20 text-[#06142f]">
    <section class="mx-auto max-w-5xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">
        AI Projects
      </p>

      <h1 class="mt-4 text-5xl font-semibold tracking-[-0.04em]">
        {title}
      </h1>

      <p class="mt-6 max-w-3xl text-xl text-slate-600">
        AI research tool evaluating MarTech vendors against a pre-determined scorecard. <br><br> The agent gathers public and uploaded evidence, scores it against a weighted rubric with evidence-strength caps, has a second AI cross-examine the result, and generates a ready-to-review Excel report with scores and supporting sources.
      </p>

 <!-- Overview -->
        <div class="mt-16 flex flex-col gap-10">
          <div>
            <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-blue-700">
              Agentic Design
            </h2>
            <p class="mt-3 text-slate-600">Researcher-Judge Workflow</p>
          </div>

          <div>
            <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-blue-700">
              Stack
            </h2>
            <p class="mt-3 text-slate-600 whitespace-nowrap">{stack.join(' · ')}</p>
          </div>
        </div>


       <!-- Action Buttons -->
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={excelHref}
          download="MarTech_Vendor_Scorecard_Single.xlsx"
          class="rounded-full border border-slate-300 px-6 py-3 text-sm font-semibold text-[#06142f] transition hover:border-blue-700 hover:text-blue-700"
        >
          Download vendor evaluation excel template
        </a>
        
       <a
        href={demoHref}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-blue-600 rounded-full border border-blue-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-yellow-400 hover:text-blue-900"
        >
  Live demo
</a>
      </div>

     
      <!-- How it works -->
      <div class="mt-16 border-t border-slate-200 pt-12">
        <h2 class="text-3xl font-semibold tracking-[-0.03em]">How it works</h2>
    
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {nodes.map((node) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-7">
              <p class="text-sm font-semibold tracking-[0.16em] text-blue-700">{node.n}</p>
              <h3 class="mt-3 text-xl font-semibold">{node.name}</h3>
              <p class="mt-3 text-slate-600">{node.body}</p>
            </div>
          ))}
        </div>
      </div>

    </section>
  </main>
</Layout>
---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const title = 'MarTech Vendor Evaluation Agent';
const description =
  'A LangGraph agent that runs a single-vendor MarTech deep-dive: gathers tiered public evidence, scores it against a weighted rubric with evidence-strength caps, and has a second model from a rival provider cross-examine the result.';

const excelHref = 'https://github.com/SauravTripathy/martech-vendor-agent/raw/main/MarTech_Vendor_Scorecard_Single.xlsx';
const demoHref = 'https://sauravtripathy-martech-vendor-agent.hf.space';

type WorkflowNode = {
  n: string;
  name: string;
  bullets: string[];
};

const nodes: WorkflowNode[] = [
  {
    n: 'STEP 1',
    name: 'Gather evidence',
    bullets: [
      'You give the agent a vendor name, your use case, and any documents you already hold, such as analyst reports or an RFP response. NOTE: Only vendor name is mandatory',
      'The agent researches the vendor across public sources including product pages, analyst coverage, customer reviews, and trust portals',
      'Every fact is mapped to the scorecard question it answers and graded by source strength, from vendor-stated to independently verifiable',
    ],
  },
  {
    n: 'STEP 2',
    name: 'Generate scores',
    bullets: [
      'The agent scores the vendor 1–5 (1=low, 5=high) on 28 weighted criteria across 8 categories',
      'Categories include functional fit, integration, AI capability, security, cost, vendor viability, lock-in risk, and implementation support',
      'Claims backed only by vendor marketing are capped at 3. Any missing evidence stays blank and is not guessed',
    ],
  },
  {
    n: 'STEP 3',
    name: 'Cross-examine & report',
    bullets: [
      'A second AI from a different provider plays judge and reviews the evidence gathered by the first agent',
      'It challenges scores that are weakly supported, flags evidence gaps, and recommends adjustments',
      'The final output is a downloadable Excel report with scores, sources, and judge dissent',
    ],
  },
];

const stack = ['Python', 'LangGraph', 'Anthropic API (researcher)', 'OpenAI API (judge)', 'Gradio'];
---

<Layout title={`${title} | Saurav Tripathy`} description={description}>
  <SiteHeader />

  <main class="min-h-screen bg-[#f8fbff] px-6 py-20 text-[#06142f]">
    <section class="mx-auto max-w-5xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">
        AI Projects
      </p>

      <h1 class="mt-4 text-5xl font-semibold tracking-[-0.04em]">
        {title}
      </h1>

      <p class="mt-6 max-w-3xl text-l text-slate-600">
    
        AI research tool evaluating MarTech vendors against a pre-determined scorecard.
          </p>

          <!-- Overview -->
        <div class="mt-8 grid gap-10 md:grid-cols-[minmax(0,0.8fr)_minmax(0,1.6fr)]">

          <div>
            <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-blue-700">
              Agentic Design
            </h2>

            <p class="mt-6 text-slate-600">Researcher-Judge Workflow</p>
          </div>

          <div>
            <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-blue-700">
              Tech Stack
            </h2>

            <p class="mt-6 text-slate-600">{stack.join(' · ')}</p>
          </div>

        </div>

      <!-- Action Buttons -->
      <div class="mt-12 flex flex-wrap gap-4">
        <a
          href={excelHref}
          download="MarTech_Vendor_Scorecard_Single.xlsx"
          class="rounded-full border border-slate-300 px-6 py-3 text-sm font-semibold text-[#06142f] transition hover:border-blue-700 hover:text-blue-700"
        >
          Download vendor evaluation template
        </a>

        <a
          href={demoHref}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full border border-blue-600 bg-yellow-400 px-6 py-3 text-sm font-semibold text-[#06142f] transition hover:bg-blue-600 hover:text-white"
        >
          Click to try demo & generate report
        </a>
      </div>

      <!-- How it works -->
      <div class="mt-12">
        <h2 class="text-2xl font-semibold tracking-[-0.03em]">How it works</h2>

        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {nodes.map((node) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-7">
              <p class="text-sm font-semibold tracking-[0.16em] text-blue-700">
                {node.n}
              </p>

              <h3 class="mt-3 text-xl font-semibold">{node.name}</h3>

              <ul class="mt-4 list-disc space-y-2 pl-5 text-sm text-slate-600">
                {node.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
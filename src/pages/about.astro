---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';

const linkedInUrl = 'https://www.linkedin.com/in/sauravtripathy/';
const email = 'sauravtripathy@yahoo.com';
const whatsappUrl = 'https://wa.me/15127580447';

const tenets = [
  {
    title: 'Customer Centricity',
    icon: 'M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4.42 0-8 2.24-8 5v1h10.2a5.5 5.5 0 0 1-.2-1.5c0-1.56.64-2.98 1.67-4A10.2 10.2 0 0 0 12 14Zm6.5 1.2c-1.16 0-2.1.62-2.6 1.48-.5-.86-1.44-1.48-2.6-1.48-1.5 0-2.8 1.2-2.8 2.75 0 2.5 5.4 5.55 5.4 5.55s5.4-3.05 5.4-5.55c0-1.55-1.3-2.75-2.8-2.75Z',
  },
  {
    title: 'Structured Problem Solving',
    icon: 'M8 3h8v5h5v8h-5v5H8v-5H3V8h5V3Z',
  },
  {
    title: 'Long-Term Thinking',
    icon: 'M12 21a9 9 0 1 0-9-9 9 9 0 0 0 9 9Zm0-4.5A4.5 4.5 0 1 0 7.5 12 4.5 4.5 0 0 0 12 16.5Zm0-3a1.5 1.5 0 1 0-1.5-1.5A1.5 1.5 0 0 0 12 13.5Zm4.5-7.5 3-3m-1 0h1v1',
  },
  {
    title: 'Next-Gen AI Solutions',
    icon: 'M7 4h10a3 3 0 0 1 3 3v3h-2V7a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1v3H4V7a3 3 0 0 1 3-3Zm11 10h2v3a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-3h2v3a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-3ZM8 8h3v3H8V8Zm5 0h3v3h-3V8Zm-5 5h3v3H8v-3Zm5 0h3v3h-3v-3Z',
  },
  {
    title: 'Bias for Execution',
    icon: 'M12 2 4 22l8-4 8 4-8-20Zm0 4.8 3.6 10.2-3.6-1.8-3.6 1.8L12 6.8Z',
  },
];

const impactOverview = [
  {
    title: 'Digital Transformation',
    text: 'Automated high-volume manual processes, optimized workflows, reduced costs.',
    icon: 'M7 4h10a3 3 0 0 1 3 3v3h-2V7a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1v3H4V7a3 3 0 0 1 3-3Zm11 10h2v3a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-3h2v3a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-3ZM8 8h3v3H8V8Zm5 0h3v3h-3V8Zm-5 5h3v3H8v-3Zm5 0h3v3h-3v-3Z',
  },
  {
    title: 'Product Management',
    text: 'Improved customer engagement, customer journeys, and customer experience.',
    icon: 'M12 2 3.5 6.75v10.5L12 22l8.5-4.75V6.75L12 2Zm0 2.3 5.9 3.3L12 10.9 6.1 7.6 12 4.3Zm-6.5 5 5.5 3.1v6.4l-5.5-3.1V9.3Zm13 0v6.4L13 18.8v-6.4l5.5-3.1Z',
  },
  {
    title: 'Sales Strategy',
    text: 'Established compliant onboarding and payment processes, shaped sales acquisition strategy for efficient growth.',
    icon: 'M4 19h16v2H4v-2Zm2-2h3V9H6v8Zm5 0h3V5h-3v12Zm5 0h3v-7h-3v7ZM4 4h2v2H4V4Zm14 0h2v2h-2V4Z',
  },
  {
    title: 'Analytics & AI',
    text: 'Led data-driven decisioning, reduced data processing time, built AI models to predict resource allocation and reduce costs.',
    icon: 'M11 2v20a10 10 0 1 1 10-10h-8V2h-2Zm4 0v6h6a8 8 0 0 0-6-6Z',
  },
];
---

<Layout
  title="About | Saurav Tripathy"
  description="About Saurav Tripathy — product and strategy professional focused on AI, analytics, product management, and digital transformation."
  showFooterCta={false}
>
  <a class="skip-link" href="#main-content">Skip to content</a>
  <SiteHeader />

  <main id="main-content" class="about-page">
    <section class="about-shell">
      <aside class="profile-card" aria-label="Profile summary">
        <img
          class="profile-photo"
          src="/saurav-headshot.jpg"
          alt="Saurav Tripathy"
          loading="eager"
        />

        <div class="profile-heading">
          <h1>Saurav Tripathy</h1>

          <div class="profile-socials" aria-label="Contact links">
            <a
              class="profile-social-icon"
              href={linkedInUrl}
              target="_blank"
              rel="noreferrer"
              aria-label="LinkedIn"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.5 8h4V24h-4V8Zm7.5 0h3.84v2.18h.05c.53-1 1.84-2.18 3.8-2.18C19.75 8 20.5 10.67 20.5 14.14V24h-4v-8.75c0-2.09-.04-4.77-2.9-4.77-2.9 0-3.35 2.27-3.35 4.62V24h-4V8Z"></path>
              </svg>
            </a>

            <a
              class="profile-social-icon"
              href={`mailto:${email}`}
              aria-label="Email"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm8 9 8-5V6l-8 5-8-5v2l8 5Z"></path>
              </svg>
            </a>

            <a
              class="profile-social-icon"
              href={whatsappUrl}
              target="_blank"
              rel="noreferrer"
              aria-label="WhatsApp"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12.04 2a9.94 9.94 0 0 0-8.62 14.9L2 22l5.25-1.38A9.98 9.98 0 1 0 12.04 2Zm0 18.2a8.18 8.18 0 0 1-4.18-1.14l-.3-.18-3.12.82.84-3.04-.2-.31a8.2 8.2 0 1 1 6.96 3.85Zm4.5-6.14c-.25-.12-1.47-.72-1.7-.8-.23-.08-.4-.12-.56.12-.17.25-.65.8-.8.96-.15.17-.3.19-.55.07-.25-.13-1.05-.39-2-1.23-.74-.66-1.24-1.48-1.38-1.73-.15-.25-.02-.38.11-.51.12-.11.25-.3.38-.45.13-.15.17-.25.25-.42.08-.17.04-.31-.02-.44-.06-.12-.56-1.35-.77-1.85-.2-.49-.41-.42-.56-.43h-.48c-.17 0-.44.06-.67.31-.23.25-.88.86-.88 2.1s.9 2.44 1.03 2.6c.13.17 1.78 2.72 4.31 3.81.6.26 1.07.41 1.44.52.6.19 1.15.16 1.58.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.15-1.18-.06-.1-.23-.17-.48-.29Z"></path>
              </svg>
            </a>
          </div>
        </div>

        <div class="profile-actions">
          <a class="button button-primary" href="/Saurav-Tripathy-CV.pdf" download>
            <span aria-hidden="true">↓</span>
            Download CV
          </a>

          <a class="button" href="/projects/chat-with-me">
            <span aria-hidden="true">○</span>
            Chat with me!
          </a>
        </div>

        <div class="sidebar-tenets" aria-label="Tenets">
          <h2>Tenets</h2>

          <div class="sidebar-tenets-list">
            {tenets.map((tenet) => (
              <article class="sidebar-tenet">
                <div class="sidebar-tenet-icon">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d={tenet.icon}></path>
                  </svg>
                </div>
                <h3>{tenet.title}</h3>
              </article>
            ))}
          </div>
        </div>
      </aside>

      <section class="about-content">
        <section class="intro-section" aria-labelledby="about-title">
          <h2 id="about-title" class="section-title">About me</h2>

          <h3 class="intro-headline">
            Product and strategy professional focused on outcome-driven, AI-led enterprise transformations.
          </h3>

          <div class="intro-copy">
            <p>
              I have 10+ years of experience across digital transformation, product management, sales strategy, and marketing analytics.
            </p>

            <p>
              I’m currently building AI & Agentic solutions that can drive scalable transformations.
            </p>

            <p>
              I hold an MBA from London Business School and an MS in Analytics from UT Austin.
            </p>
          </div>
        </section>

        <section class="section-block" aria-labelledby="impact-title">
          <div class="section-heading">
            <h2 id="impact-title" class="section-title">Impact Overview</h2>
          </div>

          <div class="background-grid">
            {impactOverview.map((item) => (
              <article class="background-card">
                <div class="icon-circle">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d={item.icon}></path>
                  </svg>
                </div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </section>
      </section>
    </section>
  </main>
</Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    background: #f8fbff;
    color: #071633;
  }

  .skip-link {
    position: absolute;
    left: -999px;
    top: 1rem;
    z-index: 100;
    border-radius: 999px;
    background: #0b4dcc;
    color: #ffffff;
    padding: 0.75rem 1rem;
    font-weight: 700;
  }

  .skip-link:focus {
    left: 1rem;
  }

  .about-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(30, 99, 255, 0.08), transparent 32rem),
      linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    padding: 3rem 1.25rem 5rem;
  }

  .about-shell {
    display: grid;
    grid-template-columns: minmax(260px, 330px) minmax(0, 1fr);
    gap: 2.5rem;
    width: min(1180px, 100%);
    margin: 0 auto;
    align-items: start;
  }

  .profile-card {
    position: sticky;
    top: 2rem;
    border: 1px solid rgba(10, 45, 95, 0.12);
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
    padding: 2rem;
  }

  .profile-photo {
    display: block;
    width: 190px;
    height: 190px;
    margin: 0 auto 1.75rem;
    border: 6px solid #ffffff;
    border-radius: 999px;
    object-fit: cover;
    box-shadow: 0 14px 35px rgba(15, 23, 42, 0.16);
  }

  .profile-heading {
    text-align: center;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(10, 45, 95, 0.12);
  }

  .profile-heading h1 {
    margin: 0;
    color: #071633;
    font-size: clamp(2rem, 2vw, 2rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .profile-heading p {
    margin: 0.65rem 0 0;
    color: #0b4dcc;
    font-weight: 800;
    font-size: 1.05rem;
  }

  .profile-socials {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 0.85rem;
    margin-top: 1rem;
  }

  .profile-social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    height: 2.35rem;
    border: 1px solid rgba(10, 45, 95, 0.16);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.85);
    color: #071633;
    text-decoration: none;
    transition:
      transform 160ms ease,
      color 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .profile-social-icon:hover {
    transform: translateY(-2px);
    color: #0b4dcc;
    border-color: rgba(11, 77, 204, 0.45);
    background: #ffffff;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.1);
  }

  .profile-social-icon svg {
    width: 1.15rem;
    height: 1.15rem;
    fill: currentColor;
  }

  .profile-actions {
    display: grid;
    gap: 0.9rem;
    margin: 1.75rem 0;
  }

  .button {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    border: 1px solid rgba(10, 45, 95, 0.24);
    border-radius: 0.85rem;
    background: #ffffff;
    color: #073075;
    padding: 0.95rem 1.1rem;
    text-decoration: none;
    font-weight: 800;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
    border-color: rgba(11, 77, 204, 0.5);
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.1);
  }

  .button-primary {
    background: linear-gradient(135deg, #0b4dcc, #073075);
    color: #ffffff;
    border-color: transparent;
  }

  .button span {
    display: inline-grid;
    place-items: center;
    width: 1.5rem;
    height: 1.5rem;
    font-size: 1.35rem;
    line-height: 1;
  }

  .sidebar-tenets {
    margin: 1.75rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(10, 45, 95, 0.12);
  }

  .sidebar-tenets h2 {
    margin: 0 0 1rem;
    color: #0b4dcc;
    font-size: 1.15rem;
    line-height: 1.2;
    font-weight: 900;
    letter-spacing: -0.025em;
  }

  .sidebar-tenets-list {
    display: grid;
    gap: 0.65rem;
  }

  .sidebar-tenet {
    display: grid;
    grid-template-columns: 2.4rem 1fr;
    align-items: center;
    gap: 0.75rem;
    padding: 0.35rem 0;
  }

  .sidebar-tenet-icon {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.75rem;
    background: rgba(11, 77, 204, 0.08);
    color: #0b4dcc;
  }

  .sidebar-tenet-icon svg {
    width: 1.25rem;
    height: 1.25rem;
    fill: currentColor;
  }

  .sidebar-tenet h3 {
    margin: 0;
    color: #071633;
    font-size: 0.9rem;
    line-height: 1.25;
    font-weight: 800;
  }

  .about-content {
    min-width: 0;
  }

  .intro-section {
    padding: 0.75rem 0 2.2rem;
  }

  .section-title {
    margin: 0 0 1.35rem;
    color: #0b4dcc;
    font-size: clamp(2.25rem, 3.4vw, 3rem);
    line-height: 1.1;
    font-weight: 900;
    letter-spacing: -0.045em;
  }

  .intro-headline {
    max-width: 860px;
    margin: 1.2rem 0 1.3rem;
    color: #071633;
    font-size: clamp(1.65rem, 2vw, 2rem);
    line-height: 1.18;
    font-weight: 850;
    letter-spacing: -0.035em;
  }

  .intro-copy {
    display: grid;
    gap: 1.15rem;
    max-width: 820px;
    color: #17243f;
    font-size: clamp(1.05rem, 2vw, 1.22rem);
    line-height: 1.7;
  }

  .intro-copy p {
    margin: 0;
  }

  .section-block {
    padding: 2rem 0;
    border-top: 1px solid rgba(10, 45, 95, 0.14);
  }

  .section-heading {
    margin-bottom: 1.35rem;
  }

  .background-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .background-card {
    border: 1px solid rgba(10, 45, 95, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.05);
    padding: 1.6rem;
  }

  .icon-circle {
    display: grid;
    place-items: center;
    width: 4.1rem;
    height: 4.1rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #0b4dcc, #073075);
    color: #ffffff;
  }

  .icon-circle svg {
    width: 1.85rem;
    height: 1.85rem;
    fill: currentColor;
  }

  .background-card h3 {
    margin: 1.1rem 0 0.65rem;
    color: #071633;
    font-size: 1.25rem;
    letter-spacing: -0.025em;
  }

  .background-card p {
    margin: 0;
    color: #203250;
    font-size: 1rem;
    line-height: 1.65;
  }

  @media (max-width: 980px) {
    .about-shell {
      grid-template-columns: 1fr;
    }

    .profile-card {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .about-page {
      padding: 1.5rem 1rem 3rem;
    }

    .profile-card {
      padding: 1.35rem;
    }

    .profile-photo {
      width: 150px;
      height: 150px;
    }

    .section-title {
      font-size: clamp(2rem, 9vw, 2.5rem);
    }

    .intro-headline {
      font-size: clamp(1.45rem, 7vw, 1.9rem);
    }

    .background-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';

const tenets = [
  {
    title: 'Customer Centricity',
    icon: 'M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4.42 0-8 2.24-8 5v1h10.2a5.5 5.5 0 0 1-.2-1.5c0-1.56.64-2.98 1.67-4A10.2 10.2 0 0 0 12 14Zm6.5 1.2c-1.16 0-2.1.62-2.6 1.48-.5-.86-1.44-1.48-2.6-1.48-1.5 0-2.8 1.2-2.8 2.75 0 2.5 5.4 5.55 5.4 5.55s5.4-3.05 5.4-5.55c0-1.55-1.3-2.75-2.8-2.75Z',
  },
  {
    title: 'Structured Thinking',
    icon: 'M8 3h8v5h5v8h-5v5H8v-5H3V8h5V3Z',
  },
  {
    title: 'Long-term impact',
    icon: 'M12 21a9 9 0 1 0-9-9 9 9 0 0 0 9 9Zm0-4.5A4.5 4.5 0 1 0 7.5 12 4.5 4.5 0 0 0 12 16.5Zm0-3a1.5 1.5 0 1 0-1.5-1.5A1.5 1.5 0 0 0 12 13.5Zm4.5-7.5 3-3m-1 0h1v1',
  },
  {
    title: 'Next-Gen Tech & AI',
    icon: 'M9 2h6v3h4v4h3v6h-3v4h-4v3H9v-3H5v-4H2V9h3V5h4V2Zm1 7v6h4V9h-4Z',
  },
  {
    title: 'Bias for Execution',
    icon: 'M12 2 4 22l8-4 8 4-8-20Zm0 4.8 3.6 10.2-3.6-1.8-3.6 1.8L12 6.8Z',
  },
];

const background = [
  {
    title: 'Digital Transformation',
    text: 'Automated high-volume manual processes, optimized workflows, reduced costs.',
    icon: 'M7 4h10a3 3 0 0 1 3 3v3h-2V7a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1v3H4V7a3 3 0 0 1 3-3Zm11 10h2v3a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-3h2v3a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-3ZM8 8h3v3H8V8Zm5 0h3v3h-3V8Zm-5 5h3v3H8v-3Zm5 0h3v3h-3v-3Z',
  },
  {
    title: 'Product Management',
    text: 'Improved customer engagement, customer journeys, and customer experience.',
    icon: 'M12 2 3.5 6.75v10.5L12 22l8.5-4.75V6.75L12 2Zm0 2.3 5.9 3.3L12 10.9 6.1 7.6 12 4.3Zm-6.5 5 5.5 3.1v6.4l-5.5-3.1V9.3Zm13 0v6.4L13 18.8v-6.4l5.5-3.1Z',
  },
  {
    title: 'Sales Strategy',
    text: 'Established compliant onboarding and payment processes, shaped acquisition strategy for efficient growth.',
    icon: 'M4 19h16v2H4v-2Zm2-2h3V9H6v8Zm5 0h3V5h-3v12Zm5 0h3v-7h-3v7ZM4 4h2v2H4V4Zm14 0h2v2h-2V4Z',
  },
  {
    title: 'Analytics & AI',
    text: 'Led data-driven decisioning, reduced data processing time, built machine learning models to predict resource allocation and reduce costs.',
    icon: 'M11 2v20a10 10 0 1 1 10-10h-8V2h-2Zm4 0v6h6a8 8 0 0 0-6-6Z',
  },
];
---

<Layout
  title="About | Saurav Tripathy"
  description="About Saurav Tripathy — product and strategy professional focused on AI, analytics, product management, and digital transformation."
  showFooterCta={false}
>
  <a class="skip-link" href="#main-content">Skip to content</a>
  <SiteHeader />

  <main id="main-content" class="about-page">
    <section class="about-shell">
      <aside class="profile-card" aria-label="Profile summary">
        <img
          class="profile-photo"
          src="/saurav-headshot.jpg"
          alt="Saurav Tripathy"
          loading="eager"
        />

        <div class="profile-heading">
          <h1>Saurav Tripathy</h1>
           </div>

                  <div class="profile-actions">
          <a class="button button-primary" href="/Saurav-Tripathy-CV.pdf" download>
            <span aria-hidden="true">↓</span>
            Download CV
          </a>

          <a class="button" href="/book-time-with-me">
            <span aria-hidden="true">□</span>
            Book time with me
          </a>

          <a class="button" href="/projects/chat-with-me">
            <span aria-hidden="true">○</span>
            Chat with me!
          </a>
        </div>

        <div class="sidebar-tenets" aria-label="Tenets">
          <h2>Tenets</h2>

          <div class="sidebar-tenets-list">
            {tenets.map((tenet) => (
              <article class="sidebar-tenet">
                <div class="sidebar-tenet-icon">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d={tenet.icon}></path>
                  </svg>
                </div>
                <h3>{tenet.title}</h3>
              </article>
            ))}
          </div>
        </div>

        <div class="contact-list" aria-label="Contact details">

          <p>📍 London, UK</p>
          <p>✉️ sauravtripathy@yahoo.com</p>
          <p>☎️ +44 737 539 2330</p>
        </div>
      </aside>

      <section class="about-content">
        <section class="intro-section" aria-labelledby="about-title">
          <h2 id="about-title" class="section-title">About me</h2>

          <h3 class="intro-headline">
            Product and strategy professional focused on outcome-driven, AI-led enterprise transformations.
          </h3>

          <div class="intro-copy">
            <p>
              I have 10+ years of experience across digital transformation, product management, sales strategy, and marketing analytics.
            </p>

            <p>
              I’m currently building AI & Agentic solutions that can drive scalable transformations.
            </p>

            <p>
              I hold an MBA from London Business School and an MS in Analytics from UT Austin.
            </p>
          </div>
        </section>

        <section class="section-block" aria-labelledby="background-title">
          <div class="section-heading">
            <h2 id="background-title" class="section-title">Impact Overview</h2>
          </div>

          <div class="background-grid">
            {background.map((item) => (
              <article class="background-card">
                <div class="icon-circle">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d={item.icon}></path>
                  </svg>
                </div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))}
          </div>
        </section>
      </section>
    </section>
  </main>
</Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    background: #f8fbff;
    color: #071633;
  }

  .skip-link {
    position: absolute;
    left: -999px;
    top: 1rem;
    z-index: 100;
    border-radius: 999px;
    background: #0b4dcc;
    color: #ffffff;
    padding: 0.75rem 1rem;
    font-weight: 700;
  }

  .skip-link:focus {
    left: 1rem;
  }

  .about-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at top left, rgba(30, 99, 255, 0.08), transparent 32rem),
      linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    padding: 3rem 1.25rem 5rem;
  }

  .about-shell {
    display: grid;
    grid-template-columns: minmax(260px, 330px) minmax(0, 1fr);
    gap: 2.5rem;
    width: min(1180px, 100%);
    margin: 0 auto;
    align-items: start;
  }

  .profile-card {
    position: sticky;
    top: 2rem;
    border: 1px solid rgba(10, 45, 95, 0.12);
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
    padding: 2rem;
  }

  .profile-photo {
    display: block;
    width: 190px;
    height: 190px;
    margin: 0 auto 1.75rem;
    border: 6px solid #ffffff;
    border-radius: 999px;
    object-fit: cover;
    box-shadow: 0 14px 35px rgba(15, 23, 42, 0.16);
  }

  .profile-heading {
    text-align: center;
    padding-bottom: 1.75rem;
    border-bottom: 1px solid rgba(10, 45, 95, 0.12);
  }

  .profile-heading h1 {
    margin: 0;
    color: #071633;
    font-size: clamp(2rem, 4vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .profile-heading p {
    margin: 0.65rem 0 0;
    color: #0b4dcc;
    font-weight: 800;
    font-size: 1.05rem;
  }

  .profile-actions {
    display: grid;
    gap: 0.9rem;
    margin: 1.75rem 0;
  }

  .sidebar-tenets {
  margin: 1.75rem 0;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(10, 45, 95, 0.12);
}

.sidebar-tenets h2 {
  margin: 0 0 1rem;
  color: #0b4dcc;
  font-size: 1.15rem;
  line-height: 1.2;
  font-weight: 900;
  letter-spacing: -0.025em;
}

.sidebar-tenets-list {
  display: grid;
  gap: 0.75rem;
}

.sidebar-tenet {
  display: grid;
  grid-template-columns: 2.4rem 1fr;
  align-items: center;
  gap: 0.75rem;
  background: rgba(255, 255, 255, 0.78);
  padding: 0.75rem;
}

.sidebar-tenet-icon {
  display: grid;
  place-items: center;
  width: 2.4rem;
  height: 2.4rem;
  border-radius: 0.75rem;
  background: rgba(11, 77, 204, 0.08);
  color: #0b4dcc;
}

.sidebar-tenet-icon svg {
  width: 1.25rem;
  height: 1.25rem;
  fill: currentColor;
}

.sidebar-tenet h3 {
  margin: 0;
  color: #071633;
  font-size: 0.9rem;
  line-height: 1.25;
  font-weight: 800;
}

  .button {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    border: 1px solid rgba(10, 45, 95, 0.24);
    border-radius: 0.85rem;
    background: #ffffff;
    color: #073075;
    padding: 0.95rem 1.1rem;
    text-decoration: none;
    font-weight: 800;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
    border-color: rgba(11, 77, 204, 0.5);
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.1);
  }

  .button-primary {
    background: linear-gradient(135deg, #0b4dcc, #073075);
    color: #ffffff;
    border-color: transparent;
  }

  .button span {
    display: inline-grid;
    place-items: center;
    width: 1.5rem;
    height: 1.5rem;
    font-size: 1.35rem;
    line-height: 1;
  }

  .contact-list {
    display: grid;
    gap: 0.85rem;
    margin-top: 1.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(10, 45, 95, 0.12);
    color: #1d2d4f;
    font-size: 0.98rem;
  }

  .contact-list p {
    margin: 0;
  }

  .about-content {
    min-width: 0;
  }

  .intro-section {
    padding: 0.75rem 0 2.2rem;
  }

  .section-title {
    margin: 0 0 1.35rem;
    color: #0b4dcc;
    font-size: clamp(2.25rem, 3.4vw, 3rem);
    line-height: 1.1;
    font-weight: 900;
    letter-spacing: -0.045em;
  }

  .intro-headline {
    max-width: 860px;
    margin: 1.2rem 0 1.3rem;
    color: #071633;
    font-size: clamp(1.5rem, 2vw, 2rem);
    line-height: 1.18;
    font-weight: 850;
    letter-spacing: -0.035em;
  }

  .intro-copy {
    display: grid;
    gap: 1.15rem;
    max-width: 820px;
    color: #17243f;
    font-size: clamp(1.05rem, 2vw, 1.22rem);
    line-height: 1.7;
  }

  .intro-copy p {
    margin: 0;
  }

  .section-block {
    padding: 2rem 0;
    border-top: 1px solid rgba(10, 45, 95, 0.14);
  }

  .section-heading {
    margin-bottom: 1.35rem;
  }

  .tenets-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  .tenet-card,
  .background-card {
    border: 1px solid rgba(10, 45, 95, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.05);
  }

  .tenet-card {
    display: grid;
    place-items: center;
    min-height: 150px;
    padding: 1.15rem 0.85rem;
    text-align: center;
  }

  .tenet-card h3 {
    margin: 0.7rem 0 0;
    color: #071633;
    font-size: 0.98rem;
    line-height: 1.25;
  }

  .icon-box,
  .icon-circle {
    display: grid;
    place-items: center;
    color: #0b4dcc;
  }

  .icon-box {
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 1rem;
    background: rgba(11, 77, 204, 0.08);
  }

  .icon-circle {
    width: 4.1rem;
    height: 4.1rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #0b4dcc, #073075);
    color: #ffffff;
  }

  svg {
    width: 1.85rem;
    height: 1.85rem;
    fill: currentColor;
  }

  .background-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .background-card {
    padding: 1.6rem;
  }

  .background-card h3 {
    margin: 1.1rem 0 0.65rem;
    color: #071633;
    font-size: 1.25rem;
    letter-spacing: -0.025em;
  }

  .background-card p {
    margin: 0;
    color: #203250;
    font-size: 1rem;
    line-height: 1.65;
  }

  @media (max-width: 980px) {
    .about-shell {
      grid-template-columns: 1fr;
    }

    .profile-card {
      position: static;
    }

    .tenets-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .about-page {
      padding: 1.5rem 1rem 3rem;
    }

    .profile-card {
      padding: 1.35rem;
    }

    .profile-photo {
      width: 150px;
      height: 150px;
    }

    .section-title {
      font-size: clamp(2rem, 9vw, 2.5rem);
    }

    .intro-headline {
      font-size: clamp(1.45rem, 7vw, 1.9rem);
    }

    .tenets-grid,
    .background-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
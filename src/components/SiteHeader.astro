---
const currentPath = Astro.url.pathname || '/';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/ai', label: 'AI' },
  { href: '/martech', label: 'MarTech' },
  { href: '/projects', label: 'Projects' },
];

const normalizePath = (path: string) =>
  path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path;

const activePath = normalizePath(currentPath);

const isActive = (href: string) => {
  if (href === '/') return activePath === '/';
  return activePath === href || activePath.startsWith(`${href}/`);
};
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white">
  <div class="mx-auto flex h-20 w-full items-center justify-center px-6">
    <nav
      class="flex items-center justify-center gap-12 text-lg font-medium text-[#06142f]"
      aria-label="Primary navigation"
    >
      {navLinks.map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class={`transition hover:text-blue-600 ${
            isActive(link.href) ? 'text-blue-700' : 'text-[#06142f]'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
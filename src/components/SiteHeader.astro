---
const currentPath = Astro.url.pathname || '/';

const navItems = [
  {
    href: '/',
    label: 'Home',
  },
  {
    href: '/about',
    label: 'About',
  },
  {
    href: '/ai',
    label: 'AI Understanding',
    children: [
      { label: 'Transformers Demystified', href: '/ai/transformer-basics' },
      { label: 'AI Solution Types', href: '/ai/solution-types' },
      { label: 'What "Agentic" Means', href: '/ai/what-agentic-means' },
    ],
  },
  {
    href: '/ai-in-enterprise',
    label: 'AI in Enterprise',
    children: [
      { label: 'Workflow Evaluation', href: '/ai-in-enterprise/workflow-evaluation' },
      { label: 'Workflow Uplift & ROI', href: '/ai-in-enterprise/workflow-uplift-and-ROI' },
      { label: 'Why AI Transformations Fail', href: '/ai-in-enterprise/why-ai-transformations-fail' },
    ],
  },
  {
    href: '/projects',
    label: 'AI Projects',
    children: [
      { label: 'MarTech Vendor Eval Agent', href: '/projects/vendor-evaluation-agent' },
      { label: 'MarTech AI News, Decoded', href: '/projects/martech-ai-news' },
    ],
  },
];

const normalizePath = (path: string) =>
  path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path;

const activePath = normalizePath(currentPath);

const isActive = (href: string) => {
  if (href === '/') return activePath === '/';
  return activePath === href || activePath.startsWith(`${href}/`);
};
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white">
  <div class="mx-auto flex h-16 w-full max-w-7xl items-center justify-between px-4 sm:px-6 lg:h-20 lg:justify-center">
    <!-- Brand (mobile / tablet only) -->
    <a
      href="/"
      class="text-lg font-bold tracking-[-0.03em] text-[#06142f] lg:hidden"
      aria-label="Saurav Tripathy — Home"
    >
      Saurav Tripathy
    </a>

    <!-- Desktop navigation -->
    <nav
      class="hidden items-center justify-center gap-12 text-lg font-medium text-[#06142f] lg:flex"
      aria-label="Primary navigation"
    >
      {navItems.map((item) => (
        item.children ? (
          <div class="group relative">
            <button
              type="button"
              aria-current={isActive(item.href) ? 'page' : undefined}
              class={`inline-flex items-center gap-2 py-7 transition hover:text-blue-600 ${
                isActive(item.href) ? 'text-blue-700' : 'text-[#06142f]'
              }`}
            >
              {item.label}
              <span class="text-sm transition group-hover:rotate-180">⌄</span>
            </button>

            <div
              class="invisible absolute left-1/2 top-full w-80 -translate-x-1/2 translate-y-2 rounded-2xl border border-blue-100 bg-white p-3 opacity-0 shadow-xl shadow-blue-950/10 transition duration-200 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100"
            >
              <div class="space-y-1">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="flex items-center gap-3 rounded-xl px-4 py-3 text-base text-slate-700 transition hover:bg-blue-50 hover:text-blue-700"
                  >
                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-100 text-sm text-blue-700">
                      →
                    </span>
                    <span>{child.label}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class={`py-7 transition hover:text-blue-600 ${
              isActive(item.href) ? 'text-blue-700' : 'text-[#06142f]'
            }`}
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <!-- Mobile menu toggle -->
    <button
      type="button"
      id="mobile-nav-toggle"
      class="inline-flex h-11 w-11 items-center justify-center rounded-full text-[#06142f] transition hover:bg-blue-50 lg:hidden"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
      aria-label="Open menu"
    >
      <span class="mobile-nav-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>

  <!-- Mobile navigation panel -->
  <nav
    id="mobile-nav-panel"
    class="hidden max-h-[calc(100dvh-4rem)] overflow-y-auto border-t border-slate-200 bg-white px-4 pb-6 pt-3 shadow-xl shadow-blue-950/10 lg:hidden"
    aria-label="Primary navigation"
  >
    <div class="mx-auto max-w-7xl space-y-1 sm:px-2">
      {navItems.map((item) => (
        item.children ? (
          <details class="mobile-nav-group" open={isActive(item.href)}>
            <summary
              class={`flex min-h-[44px] cursor-pointer list-none items-center justify-between gap-3 rounded-xl px-3 py-2.5 text-base font-semibold ${
                isActive(item.href) ? 'text-blue-700' : 'text-[#06142f]'
              }`}
            >
              {item.label}
              <span class="mobile-nav-chevron text-sm text-slate-500" aria-hidden="true">⌄</span>
            </summary>

            <div class="space-y-1 pb-2 pl-3">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  aria-current={isActive(child.href) ? 'page' : undefined}
                  class={`flex min-h-[44px] items-center gap-3 rounded-xl px-3 py-2.5 text-base transition hover:bg-blue-50 hover:text-blue-700 ${
                    isActive(child.href) ? 'bg-blue-50 text-blue-700' : 'text-slate-700'
                  }`}
                >
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-100 text-sm text-blue-700">
                    →
                  </span>
                  <span>{child.label}</span>
                </a>
              ))}
            </div>
          </details>
        ) : (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class={`flex min-h-[44px] items-center rounded-xl px-3 py-2.5 text-base font-semibold transition hover:bg-blue-50 hover:text-blue-700 ${
              isActive(item.href) ? 'text-blue-700' : 'text-[#06142f]'
            }`}
          >
            {item.label}
          </a>
        )
      ))}
    </div>
  </nav>
</header>

<style>
  .mobile-nav-icon {
    display: inline-grid;
    gap: 5px;
  }

  .mobile-nav-icon span {
    display: block;
    width: 20px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transition: transform 160ms ease, opacity 160ms ease;
  }

  #mobile-nav-toggle[aria-expanded='true'] .mobile-nav-icon span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  #mobile-nav-toggle[aria-expanded='true'] .mobile-nav-icon span:nth-child(2) {
    opacity: 0;
  }

  #mobile-nav-toggle[aria-expanded='true'] .mobile-nav-icon span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-nav-group summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav-chevron {
    transition: transform 160ms ease;
  }

  .mobile-nav-group[open] .mobile-nav-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('#mobile-nav-toggle');
  const panel = document.querySelector<HTMLElement>('#mobile-nav-panel');

  const setOpen = (open: boolean): void => {
    if (!toggle || !panel) return;

    panel.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  };

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!isOpen);
  });

  panel?.addEventListener('click', (event) => {
    const target = event.target;
    if (target instanceof Element && target.closest('a')) {
      setOpen(false);
    }
  });

  document.addEventListener('keydown', (event: KeyboardEvent) => {
    if (event.key === 'Escape') {
      setOpen(false);
    }
  });

  const desktopQuery = window.matchMedia('(min-width: 1024px)');
  desktopQuery.addEventListener('change', (event) => {
    if (event.matches) {
      setOpen(false);
    }
  });
</script>
